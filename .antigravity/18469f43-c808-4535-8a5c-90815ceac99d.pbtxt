        lines {
          text: "      \"story_en\": \"Admitted to Harvard with an acceptance rate under 3%. Asel developed a mobile app for Kazakh university entrance prep, which served as a major social impact project in her application. She scored 1560 on the SAT and 8.5 on the IELTS.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
