        }
        lines {
          text: "      \"description_ru\": \"\320\222\321\213\321\201\321\202\321\203\320\277\320\273\320\265\320\275\320\270\321\217 \320\220\321\201\320\265\320\273\321\214 \320\220\320\273\320\270\320\274\320\266\320\260\320\275\320\276\320\262\320\276\320\271 (Harvard) \320\270 \320\234\320\260\320\273\320\270\320\272\320\270 \320\230\321\201\320\272\320\260\320\272\320\276\320\262\320\276\320\271 (Cornell) \320\276 \321\201\321\202\321\200\321\203\320\272\321\202\321\203\321\200\320\265 \321\203\321\201\320\277\320\265\321\210\320\275\320\276\320\263\320\276 \320\277\320\276\321\200\321\202\321\204\320\276\320\273\320\270\320\276.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
