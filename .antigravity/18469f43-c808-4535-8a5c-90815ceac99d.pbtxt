\320\260\320\272\320\276\320\262\320\276\320\271 (Cornell) \320\276 \321\201\321\202\321\200\321\203\320\272\321\202\321\203\321\200\320\265 \321\203\321\201\320\277\320\265\321\210\320\275\320\276\320\263\320\276 \320\277\320\276\321\200\321\202\321\204\320\276\320\273\320\270\320\276.\",\n      \"description_en\": \"Learn critical tricks from Asel Alimzhanova (Harvard) and Malika Iskakova (Cornell) on creative presentation.\",\n      \"speakerId\": \"1\"\n    },\n    {\n      \"id\": \"s4\",\n      \"time\": \"11:15 - 12:00\",\n      \"title_ru\": \"\320\237\320\260\320\275\320\265\320\273\321\214 2: \320\241\321\202\321\215\320\275\321\204\320\276\321\200\320\264, \320\232\320\265\320\274\320\261\321\200\320\270\320\264\320\266 \320\270 \320\234\320\265\320\266\320\264\320\270\321\201\321\206\320\270\320\277\320\273\320\270\320\275\320\260\321\200\320\275\320\276\321\201\321\202\321\214\",\n      \"title_en\": \"Session 2: Stanford & Cambridge Engineering Tracks\",\n      \"description_ru\": \"\320\240\320\260\320\271\320\263\321\203\320\273\321\214 \320\220\321\205\320\274\320\265\321\202\320\276\320\262\320\260 (Stanford) \320\270 \320\241\321\203\320\273\321\202\320\260\320\275\320\261\320\265\320\272 \320\221\320\265\320\272\320\265\321\202\320\276\320\262 (Cambridge) \320\276\320\261 \321\203\320\275\320\270\320\272\320\260\320\273\321\214\320\275\321\213\321\205 \320\270\320\275\320\266\320\265\320\275\320\265\321\200\320\275\321\213\321\205 \320\270 \320\273\320\270\320\275\320\263\320\262\320\270\321\201\321\202\320\270\321\207\320\265\321\201\320\272\320\270\321\205 \320\272\320\265\320\271\321\201\320\260\321\205.\",\n      \"description_en\": \"Engaging lessons from Raygul Akhmetova (Stanford) and Sultanbek Beketov (Cambridge) about system pipelines.\",\n      \"speakerId\": \"2\"\n    },\n    {\n      \"id\": \"s5\",\n      \"time\": \"12:00 - 13:00\",\n      \"title_ru\": \"\320\242\320\265\321\205\320\275\320\276\320\273\320\276\320\263\320\270\321\207\320\265\321\201\320\272\320\270\320\271 \320\241\321\202\320\265\320\272: \320\244\320\270\320\267\320\270\320\272\320\260, \320\240\320\276\320\261\320\276\321\202\320\276\321\202\320\265\321\205\320\275\320\270\320\272\320\260, MIT \320\270 Caltech\",\n      \"title_en\": \"Session 3: Hard Science Frontiers & Deep STEM\",\n      \"description_ru\": \"\320\232\321\200\321\203\320\263\320\273\321\213\320\271 \321\201\321\202\320\276\320\273 \321\201 \321\203\321\207\320\260\321\201\321\202\320\270\320\265\320\274 \320\224\320\260\320\275\320\270\320\260\320\273\320\260 \320\241\320\265\321\200\320\270\320\272\320\276\320\262\320\260 (MIT) \320\270 \320\225\321\200\320\260\321\201\321\213\320\273\320\260 \320\235\321\203\321\200\320\277\320\265\320\270\321\201\320\276\320\262\320\260 (Caltech). \320\232\320\260\320\272 \321\201\320\276\320\261\320\270\321\200\320\260\321\202\321\214 \321\202\320\265\321\205\320\275\320\270\321\207\320\265\321\201\320\272\320\276\320\265 \320\277\320\276\321\200\321\202\321\204\320\276\320\273\320\270\320\276.\",\n      \"description_en\": \"Deep dive discussion with Danial Serikov (MIT) and Erasyl Nurpeisov (Caltech) regarding top tech pipelines.\",\n      \"speakerId\": \"3\"\n    },\n    {\n      \"id\": \"s6\",\n      \"time\": \"13:00 - 14:00\",\n      \"title_ru\": \"\320\236\320\261\320\265\320\264 \320\270 \320\235\320\265\321\202\320\262\320\276\321\200\320\272\320\270\320\275\320\263\",\n      \"title_en\": \"Catered Lunch & Peer Mentoring Meetup\",\n      \"description_ru\": \"\320\223\320\276\321\200\321\217\321\207\320\270\320\271 \320\276\320\261\320\265\320\264 \320\262 \321\205\320\276\320\273\320\273\320\265 \320\242\320\265\321\205\320\275\320\276\320\277\320\260\321\200\320\272\320\260. \320\227\320\276\320\275\321\213 \320\272\320\276\320\275\321\201\321\203\320\273\321\214\321\202\320\260\321\206\320\270\320\271: \320\262\320\276\320\267\320\274\320\276\320\266\320\275\320\276\321\201\321\202\321\214 \320\267\