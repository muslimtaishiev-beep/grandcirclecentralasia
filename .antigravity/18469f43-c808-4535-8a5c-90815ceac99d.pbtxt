        target_content: "  return (\n    <div className=\"mx-auto max-w-6xl text-center\" id=\"partners_panel_container\">\n      {/* Little Tag */}\n      <span className=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-500 tracking-wider uppercase font-mono\">\n        {lang === \"ru\" ? \"\320\255\320\232\320\236\320\241\320\230\320\241\320\242\320\225\320\234\320\220\" : \"ECOSYSTEM PARTNERS\"}\n      </span>\n      <h2 className=\"mt-3 text-2xl font-black text-slate-800 tracking-tight sm:text-3xl\" id=\"partners_sec_title\">\n        {lang === \"ru\" ? \"\320\237\321\200\320\270 \320\277\320\276\320\264\320\264\320\265\321\200\320\266\320\272\320\265 \320\262\320\265\320\264\321\203\321\211\320\270\321\205 \320\261\321\200\320\265\320\275\320\264\320\276\320\262\" : \"Supported by Trusted Leagues\"}\n      </h2>\n\n      {/* Tiers distribution */}\n      <div className=\"mt-12 space-y-12\">\n        {/* Tier 1: General Partner (Astana Technopark) */}\n        {general.length > 0 && (\n          <div className=\"space-y-4\" id=\"tier_general\">\n            <h3 className=\"text-2xs font-extrabold text-sky-400 uppercase tracking-widest font-mono\">\n              \342\230\205 {lang === \"ru\" ? \"\320\223\320\265\320\275\320\265\321\200\320\260\320\273\321\214\320\275\321\213\320\271 \320\277\320\260\321\200\321\202\320\275\320\265\321\200 \320\270 \320\234\320\265\321\201\321\202\320\276 \320\277\321\200\320\276\320\262\320\265\320\264\320\265\320\275\320\270\321\217\" : \"General Host Partner\"} \342\230\205\n            </h3>\n            <div className=\"flex justify-center flex-wrap gap-6\">\n              {general.map((p) => (\n                <div\n                  key={p.id}\n                  className=\"inline-flex flex-col items-center justify-center rounded-2xl border border-sky-100 bg-sky-50/20 px-8 py-6 shadow-sm min-w-[240px] transition-all hover:shadow-md hover:border-sky-300\"\n                  id={`partner_${p.id}`}\n                >\n                  <Landmark className=\"h-6 w-6 text-sky-400 mb-2.5\" />\n                  <span className=\"text-base font-extrabold text-slate-800 tracking-tight\">{p.name}</span>\n                  <span className=\"text-3xs font-semibold text-slate-400 uppercase tracking-wider mt-1.5 font-mono\">\n                    {lang === \"ru\" ? p.role_ru : p.role_en}\n                  </span>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {/* Tier 2: Academic Sponsors / Leaders */}\n        {sponsors.length > 0 && (\n          <div className=\"space-y-4\" id=\"tier_sponsors\">\n            <h3 className=\"text-2xs font-extrabold text-indigo-400 uppercase tracking-widest font-mono\">\n              \342\234\246 {lang === \"ru\" ? \"\320\220\320\272\320\260\320\264\320\265\320\274\320\270\321\207\320\265\321\201\320\272\320\270\320\265 \321\201\320\277\320\276\320\275\321\201\320\276\321\200\321\213\" : \"Academic Language Sponsors\"} \342\234\246\n            </h3>\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto\">\n              {sponsors.map((p) => (\n                <div\n                  key={p.id}\n                  className=\"flex items-center space-x-4 rounded-xl border border-slate-100 bg-white p-5 text-left shadow-xs transition hover:border-slate-300 hover:shadow-xs\"\n                  id={`partner_${p.id}`}\n                >\n                  <div className=\"rounded-lg bg-indigo-50 p-2.5 text-indigo-500\">\n                    <Award className=\"h-5 w-5\" />\n                  </div>\n                  <div>\n                    <span className=\"block text-sm sm:text-base font-bold text-slate-800 tracking-tight\">{p.name}</span>\n                    <span className=\"text-4xs font-bold text-slate-400 uppercase tracking-wider font-mono\">\n                      {lang === \"ru\" ? p.role_ru : p.role_en}\n                    </span>\n                  