\320\273\321\214\320\267\321\203\320\265\320\274 \321\201\320\270\320\273\321\203 \321\202\320\270\320\277\320\276\320\263\321\200\320\260\321\204\320\270\320\272\320\270 \320\270 \320\277\321\200\320\276\321\201\321\202\321\200\320\260\320\275\321\201\321\202\320\262\320\260. \320\224\320\265\320\272\320\276\321\200\320\276\320\274 \320\274\320\276\320\263\321\203\321\202 \320\262\321\213\321\201\321\202\321\203\320\277\320\260\321\202\321\214 \321\202\320\276\320\275\320\272\320\270\320\265 \320\272\320\276\320\276\321\200\320\264\320\270\320\275\320\260\321\202\320\275\321\213\320\265 \321\201\320\265\321\202\320\272\320\270 (Grid), \320\273\320\265\320\263\320\272\320\270\320\265 \321\200\320\260\320\267\320\274\321\213\321\202\321\213\320\265 \321\201\320\270\320\275\320\265-\320\263\320\276\320\273\321\203\320\261\321\213\320\265 \321\201\320\262\320\265\321\207\320\265\320\275\320\270\321\217 (Blur gradients) \320\275\320\260 \320\267\320\260\320\264\320\275\320\265\320\274 \321\204\320\276\320\275\320\265, \320\272\320\276\321\202\320\276\321\200\321\213\320\265 \321\201\320\276\320\267\320\264\320\260\321\216\321\202 \320\263\320\273\321\203\320\261\320\270\320\275\321\203, \320\275\320\276 \320\275\320\265 \320\276\321\202\320\262\320\273\320\265\320\272\320\260\321\216\321\202 \320\276\321\202 \321\202\320\265\320\272\321\201\321\202\320\260.\n7. \320\241\321\206\320\265\320\275\320\260\321\200\320\270\320\271 \320\277\320\273\320\260\320\262\320\275\321\213\321\205 \320\260\320\275\320\270\320\274\320\260\321\206\320\270\320\271 (Motion Design)\n\320\247\321\202\320\276\320\261\321\213 \321\201\320\260\320\271\321\202 \320\276\321\211\321\203\321\211\320\260\320\273\321\201\321\217 \320\277\321\200\320\265\320\274\320\270\320\260\320\273\321\214\320\275\321\213\320\274 (\320\272\320\260\320\272 \321\200\320\265\321\204\320\265\321\200\320\265\320\275\321\201 youthforum.org), \320\260\320\275\320\270\320\274\320\260\321\206\320\270\321\217 \320\264\320\276\320\273\320\266\320\275\320\260 \320\261\321\213\321\202\321\214 \302\253\320\264\320\270\321\201\320\272\321\200\320\265\321\202\320\275\320\276\320\271\302\273 \342\200\224 \320\277\320\273\320\260\320\262\320\275\320\276\320\271, \320\264\320\276\321\200\320\276\320\263\320\276\320\271, \320\261\320\265\320\267 \321\200\320\265\320\267\320\272\320\276\320\263\320\276 \320\264\320\265\321\200\320\263\320\260\320\275\321\214\321\217. \320\230\321\201\320\277\320\276\320\273\321\214\320\267\321\203\320\265\320\274 \320\261\320\270\320\261\320\273\320\270\320\276\321\202\320\265\320\272\321\203 GSAP \320\270\320\273\320\270 Framer Motion.\n1 Smooth Scroll: \320\230\320\275\321\202\320\265\320\263\321\200\320\260\321\206\320\270\321\217 \320\277\320\273\320\260\320\262\320\275\320\276\320\263\320\276 \321\201\320\272\321\200\320\276\320\273\320\273\320\260 \320\277\320\276 \320\262\321\201\320\265\320\271 \321\201\321\202\321\200\320\260\320\275\320\270\321\206\320\265 (\320\275\320\260\320\277\321\200\320\270\320\274\320\265\321\200, \321\207\320\265\321\200\320\265\320\267 Lenis Scroll), \321\207\321\202\320\276\320\261\321\213 \320\277\321\200\320\276\320\272\321\200\321\203\321\202\320\272\320\260 \321\210\320\273\320\260 \320\274\321\217\320\263\320\272\320\276, \320\272\320\260\320\272 \320\275\320\260 Mac-\321\203\321\201\321\202\321\200\320\276\320\271\321\201\321\202\320\262\320\260\321\205.\n2 Hero Animation: \320\237\321\200\320\270 \320\267\320\260\320\263\321\200\321\203\320\267\320\272\320\265 \321\201\321\202\321\200\320\260\320\275\320\270\321\206\321\213 \320\263\320\273\320\260\320\262\320\275\321\213\320\271 \320\267\320\260\320\263\320\276\320\273\320\276\320\262\320\276\320\272 \320\270 \320\272\320\275\320\276\320\277\320\272\320\260 \320\277\320\276\321\217\320\262\320\273\321\217\321\216\321\202\321\201\321\217 \320\275\320\265 \320\276\320\264\320\275\320\276\320\262\321\200\320\265\320\274\320\265\320\275\320\275\320\276, \320\260 \321\201 \320\273\320\265\320\263\320\272\320\276\320\271 \320\272\320\260\321\201\320\272\320\260\320\264\320\275\320\276\320\271 \320\267\320\260\320\264\320\265\321\200\320\266\320\272\320\276\320\271 (Stagger \321\215\321\204\321\204\320\265\320\272\321\202) \320\270 \320\277\320\273\320\260\320\262\320\275\321\213\320\274 \320\277\320\276\320\264\321\212\320\265\320\274\320\276\320\274 \321\201\320\275\320\270\320\267\321\203 \320\262\320\262\320\265\321\200\321\205 \320\275\320\260 20px (fade-in-up).\n3 Scroll Trigger (\320\237\320\276\321\217\320\262\320\273\320\265\320\275\320\270\320\265 \320\277\321\200\320\270 \321\201\320\272\321\200\320\276\320\273\320\273\320\265): \320\221\320\273\320\276\320\272\320\270 \302\253\320\236 \321\204\320\276\321\200\321\203\320\274\320\265\302\273 \320\270 \302\253\320\241\320\277\320\270\320\272\320\265\321\200\321\213\302\273 \320\277\321\200\320\276\321\217\320\262\320\273\321\217\321\216\321\202\321\201\321\217 \320\270\320\267 \320\277\321\200\320\276\320\267\321\200\320\260\321\207\320\275\320\276\321\201\321\202\320\270 \320\277\320\276 \320\274\320\265\321\200\320\265 \321\202\320\276\320\263\320\276, \320\272\320\260\320\272 \320\277\320\276\320\273\321\214\320\267\320\276\320\262\320\260\321\202\320\265\320\273\321\214 \320\264\320\276 \320\275\320\270\321\205 \320\264\320\276\320\273\320\270\321\201\321\202\321\213\320\262\320\260\320\265\321\202.\n4 Hover-\321\215\321\204\321\204\320\265\320\272\321\202\321\213: * \320\237\321\200\320\270 \320\275\320\260\320\262\320\265\320\264\320\265\320\275\320\270\320\270 \320\275\320\260 \320\272\320\260\321\200\321\202\320\276\321\207\320\272\321\203 \321\201\320\277\320\270\320\272\320\265\321\200\320\260 \320\270\320\273\320\270 \321\202\320\260\321\200\320\270\321\204\320\260 \342\200\224 \320\276\320\275\320\260 \321\201\320\273\320\265\320\263\320\272\320\260 (\320\275\320\260 2-3 \320\277\320\270\320\272\321\201\320\265\320\273\321\217) \320\277\321\200\320\270\320\277\320\276\320\264\320\275\320\270\320\274\320\260\320\265\321\202\321\201\321\217 \320\262\320\262\320\265\321\200\321\205, \320\260 \321\202\320\265\320\275\321\214 \320\277\320\276\320\264 \320\275\320\265\320\271 \321\201\321\202\320\260\320\275\320\276\320\262\320\270\321\202\321\201\321\217 \321\207\321\203\321\202\321\214 \320\274\321\217\320\263\321\207\320\265, \320\273\320\270\320\261\320\276 \320\274\320\265\320\275\321\217\320\265\321\202\321\201\321\217 \321\206\320\262\320\265\321\202 \321\200\320\260\320\274\320\272\320\270 \320\275\320\260 \320\275\320\260\321\210 \320\260\320\272\321\206\320\265\320\275\321\202\320\275\321\213\320\271 \320\274\321\217\320\263\320\272\320\276-\321\201\320\270\320\275\320\270\320\271.\n \320\237\321\200\320\270 \320\275\320\260\320\262\320\265\320\264\320\265\320\275\320\270\320\270 \320\275\320\260 \320\272\320\275\320\276\320\277\320\272\320\270 \342\200\224 \321\201\321\202\321\200\320\265\320\273\320\276\321\207\320\272\320\270 \320\262\320\275\321\203\321\202\321\200\320\270 \320\275\320\270\321\205 \320\277\320\273\320\260\320\262\320\275\320\276 \321\201\320\274\320\265\321\211\320\260\321\216\321\202\321\201\321\217 \320\262\320\277\321\200\320\260\320\262\320\276 \320\275\320\260 \320\275\320\265\321\201\320\272\320\276\320\273\321\214\320\272\320\276 \320\277\320\270\320\272\321\201\320\265\320\273\320\265\320\271.\n5 Pop-up \320\241\320\277\320\270\320\272\320\265\321\200\320\276\320\262: \320\237\321\200\320\270 \320\272\320\273\320\270\320\272\320\265 \320\275\320\260 \321\201\320\277\320\270\320\272\320\265\321\200\320\260 \320\274\320\276\320\264\320\260\320\273\321\214\320\275\320\276\320\265 \320\276\320\272\320\275\320\276 \320\275\320\265 \320\277\321\200\320\276\321\201\321\202\320\276 \302\253\320\262\321\213\320\277\321\200\321\213\320\263\320\270\320\262\320\260\320\265\321\202\302\273, \320\260 \320\277\320\273\320\260\320\262\320\275\320\276 \321\200\320\260\320\267\320\262\320\276\321\200\320\260\321\207\320\270\320\262\320\260\320\265\321\202\321\201\321\217 \320\270\320\267 \321\206\320\265\320\275\321\202\321\200\320\260 \321\201 \320\273\320\265\320\263\320\272\320\270\320\274 \321\200\320\260\320\267\320\274\321\213\321\202\320\270\320\265\320\274 \320\267\320\260\320\264\320\275\320\265\320\263\320\276 \321\204\320\276\320\275\320\260 (backdrop-filter: blur). \320\270\321\201\320\277\320\276\320\273\321\214\320\267\321\203\320\271 \320\277\321\200\320\270\320\274\320\265\321\200\321\213 \320\272\320\276\321\202\320\276\321\200\321\213\320\265 \320\274\320\275\320\265 \320\277\320\276\320\275\321\200\320\260\320\262\320\270\320\273\320\270\321\201\321\214 \320\270 \320\264\320\276\320\261\320\260\320\262\321\214 \321\215\321\204\321\204\320\265\320\272\321\202 \320\277\320\260\321\200\320\260\320\273\320\273\320\260\320\272\321\201\320\260 \320\277\321\200\320\270 \320\277\321\200\320\276\320\272\321\200\321\203\321\202\320\272\320\265 \321\201\321\202\321\200\320\260\320\275\320\270\321\206. \320\242\320\260\320\272\320\266\320\265 \320\270\320\275\321\202\320\265\320\263\321\200\320\270\321\200\321\203\320\271 \320\277\320\273\320\260\320\262\320\275\321\213\320\265 \320\260\320\275\320\270\320\274\320\260\321\206\320\270\320\270 \320\277\320\276\321\217\320\262\320\273\320\265\320\275\320\270\321\217 \321\202\320\265\320\272\321\201\321\202\320\260 \320\277\321\200\320\270 \321\201\320\272\321\200\320\276\320\273\320\273\320\265. \320\275\320\265 \320\270\321\201\320\277\320\276\320\273\321\214\320\267\321\203\320\271 \320\264\320\270\320\267\320\260\320\271\320\275\320\265\321\200\321\201\320\272\320\270\320\265 \320\270\320\275\321\201\321\202\321\200\321\203\320\274\320\265\320\275\321\202\321\213 \320\272\320\276\321\202\320\276\321\200\321\213\320\265 \320\270\321\201\320\277\320\276\320\273\321\214\320\267\321\203\320\265\321\202 \320\270\320\270 \320\262 \320\261\320\276\320\273\321\214\321\210\320\270\320\275\321\201\321\202\320\262\320\265 \321\201\320\273\321\203\321\207\320\260\320\265\321\202(\320\261\320\265\321\201\321\201\320\274\321\213\321\201\320\273\320\265\320\275\320\275\321\213\320\265 \321\202\320\265\320\274\320\275\321\213\320\265 \320\263\321\200\320\260\320\264\320\270\320\265\321\202\321\213 \320\270\320\273\320\270 \321\210\320\260\320\261\320\273\320\276\320\275\320\275\321\213\320\265 \320\275\320\265\320\276\320\275\320\276\320\262\321\213\320\265 \321\215\320\273\320\265\320\274\320\265\320\275\321\202\321\213). \320\222\320\274\320\265\321\201\321\202\320\276 \320\275\320\270\321\205 \321\201\320\276\321\201\321\200\320\265\320\264\320\276\321\202\320\276\321\207\321\214\321\201\321\217 \320\275\320\260 \320\274\320\270\320\275\320\270\320\274\320\260\320\273\320\270\321\201\321\202\320\270\321\207\320\275\320\276\320\271 \321\202\320\270\320\277\320\276\320\263\321\200\320\260\321\204\320\270\320\272\320\265 \320\270 \320\262\321\213\321\201\320\276\320\272\320\276\320\271 \320\272\320\276\320\275\321\202\321\200\320\260\321\201\321\202\320\275\320\276\321\201\321\202\320\270. "
