  file_change {
    absolute_path_uri: "file:///src/components/Header.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \"react\";\nimport { Globe, Shield, Sparkles } from \"lucide-react\";\n\ninterface HeaderProps {\n  lang: \"ru\" | \"en\";\n  setLang: (l: \"ru\" | \"en\") => void;\n  isAdminOpen: boolean;\n  setIsAdminOpen: (b: boolean) => void;\n}\n\nexport default function Header({ lang, setLang, isAdminOpen, setIsAdminOpen }: HeaderProps) {\n  const scrollTo = (id: string) => {\n    const el = document.getElementById(id);\n    if (el) {\n      el.scrollIntoView({ behavior: \"smooth\" });\n    }\n  };\n\n  return (\n    <header className=\"sticky top-0 z-40 w-full border-b border-slate-100 bg-white/80 backdrop-blur-md transition-colors\" id=\"header_container\">\n      <div className=\"mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8\">\n        {/* Logo / Title */}\n        <div \n          onClick={() => scrollTo(\"hero\")} \n          className=\"flex cursor-pointer items-center space-x-2 text-slate-900 transition hover:opacity-85\"\n          id=\"logo_btn\"\n        >\n          <Sparkles className=\"h-5 w-5 text-sky-400\" />\n          <span className=\"font-sans font-bold tracking-tight text-slate-800\">\n            THE MAIN <span className=\"text-sky-500 font-extrabold font-mono\">2026</span>\n          </span>\n        </div>\n\n        {/* Desktop Navigation */}\n        <nav className=\"hidden md:flex items-center space-x-8 text-sm font-medium text-slate-600\">\n          <button \n            onClick={() => scrollTo(\"speakers\")} \n            className=\"transition hover:text-sky-500 hover:underline cursor-pointer\"\n            id=\"nav_speakers\"\n          >\n            {lang === \"ru\" ? \"\320\241\320\277\320\270\320\272\320\265\321\200\321\213\" : \"Speakers\"}\n          </button>\n          <button \n            onClick={() => scrollTo(\"schedule\")} \n            className=\"transition hover:text-sky-500 hover:underline cursor-pointer\"\n            id=\"nav_schedule\"\n          >\n            {lang === \"ru\" ? \"\320\237\321\200\320\276\320\263\321\200\320\260\320\274\320\274\320\260\" : \"Program\"}\n          </button>\n          <button \n            onClick={() => scrollTo(\"tickets\")} \n            className=\"transition hover:text-sky-500 hover:underline cursor-pointer\"\n            id=\"nav_tickets\"\n          >\n            {lang === \"ru\" ? \"\320\221\320\270\320\273\320\265\321\202\321\213\" : \"Tickets\"}\n          </button>\n          <button \n            onClick={() => scrollTo(\"partners\")} \n            className=\"transition hover:text-sky-500 hover:underline cursor-pointer\"\n            id=\"nav_partners\"\n          >\n            {lang === \"ru\" ? \"\320\237\320\260\321\200\321\202\320\275\320\265\321\200\321\213\" : \"Partners\"}\n          </button>\n        </nav>\n\n        {/* Global Controls & Actions */}\n        <div className=\"flex items-center space-x-3 sm:space-x-4\">\n          {/* Language Switch Panel */}\n          <div className=\"flex items-center bg-slate-50 border border-slate-200/60 rounded-full p-0.5\" id=\"lang_switcher\">\n            <button\n              onClick={() => setLang(\"ru\")}\n              className={`px-3 py-1 text-xs font-semibold rounded-full transition-all ${\n                lang === \"ru\" \n                  ? \"bg-white text-slate-900 shadow-sm border border-slate-200/50\" \n                  : \"text-slate-400 hover:text-slate-600\"\n              }`}\n              id=\"btn_lang_ru\"\n            >\n              RU\n            </button>\n            <button\n              onClick={() => setLang(\"en\")}\n              className={`px-3 py-1 text-xs font-semibold rounded-full transition-all ${\n                lang === \"en\" \n                  ? \"bg-white text-slate-900 shadow-sm border border-slate-200/50\" \n                  : \"text-slate-400 hover:text-slate-600\"\n              }`}\n              id=\"btn_lang_en\"\n            >\n              EN\n            </button>\n          </div>\n\n          {/* CMS Admin Button */}\n          <button\n            onClick={() => setIsAdminOpen(!isAdminOpen)}\n            className={`flex items-center space-x-1.5 rounded-full border px-3 py-1.5 text-xs font-medium cursor-pointer transition ${\n              isAdminOpen \n                ? \"bg-sky-50 border-sky-200 text-sky-600 shadow-inner\" \n                : \"border-slate-200 hover:bg-slate-50 text-slate-600\"\n            }`}\n            title=\"CMS Panel\"\n            id=\"admin_panel_toggle_btn\"\n          >\n            <Shield className=\"h-3.5 w-3.5\" />\n            <span className=\"hidden sm:inline\">\n              {isAdminOpen ? (lang === \"ru\" ? \"\320\222\321\213\320\271\321\202\320\270\" : \"Exit CMS\") : (lang === \"ru\" ? \"\320\220\320\264\320\274\320\270\320\275\320\272\320\260\" : \"CMS Panel\")}\n            </span>\n          </button>\n\n          {/* Quick Registration Button */}\n          <button\n            onClick={() => scrollTo(\"tickets\")}\n            className=\"hidden sm:flex items-center justify-center rounded-full bg-slate-950 px-4 py-1.5 text-xs font-semibold text-white tracking-wide shadow-md hover:bg-slate-800 hover:scale-101 active:scale-99 transition-all cursor-pointer\"\n            id=\"header_cta_btn\"\n          >\n            {lang === \"ru\" ? \"\320\227\320\260\320\261\321\200\320\276\320\275\320\270\321\200\320\276\320\262\320\260\321\202\321\214\" : \"Buy Passes\"}\n          </button>\n        </div>\n      </div>\n    </header>\n  );\n}\n"
    }
    diff {
