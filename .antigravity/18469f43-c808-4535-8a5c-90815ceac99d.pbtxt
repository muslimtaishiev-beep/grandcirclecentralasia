  file_change {
    absolute_path_uri: "file:///src/components/SchedulePanel.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \"react\";\nimport { Clock, MessageSquare, ChevronDown, ChevronUp, User, Globe } from \"lucide-react\";\nimport { ProgramSlot, Speaker } from \"../types\";\n\ninterface SchedulePanelProps {\n  program: ProgramSlot[];\n  speakers: Speaker[];\n  lang: \"ru\" | \"en\";\n}\n\nexport default function SchedulePanel({ program, speakers, lang }: SchedulePanelProps) {\n  const [expandedSlots, setExpandedSlots] = useState<Record<string, boolean>>({\n    \"s1\": true, // Pre-expand first slot\n    \"s3\": true, // Pre-expand key session\n  });\n\n  const toggleSlot = (id: string) => {\n    setExpandedSlots(prev => ({\n      ...prev,\n      [id]: !prev[id]\n    }));\n  };\n\n  // Find associated speaker for a slot\n  const findSpeaker = (speakerId: string): Speaker | undefined => {\n    if (!speakerId) return undefined;\n    return speakers.find(s => s.id === speakerId);\n  };\n\n  const scrollToSpeaker = (speakerId: string) => {\n    const el = document.getElementById(`speaker_card_${speakerId}`);\n    if (el) {\n      el.scrollIntoView({ behavior: \"smooth\", block: \"center\" });\n      // Add a brief flashing highlight\n      el.classList.add(\"ring-4\", \"ring-sky-400\", \"ring-offset-2\");\n      setTimeout(() => {\n        el.classList.remove(\"ring-4\", \"ring-sky-400\", \"ring-offset-2\");\n      }, 2000);\n    }\n  };\n\n  return (\n    <div className=\"mx-auto max-w-4xl\" id=\"schedule_panel_container\">\n      {/* Intro text */}\n      <div className=\"text-center mb-10\">\n        <span className=\"rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-600 tracking-wider uppercase font-mono\">\n          {lang === \"ru\" ? \"\320\237\320\240\320\236\320\223\320\240\320\220\320\234\320\234\320\220 \320\224\320\235\320\257\" : \"AGENDA TIMELINE\"}\n        </span>\n        <h2 className=\"mt-3 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl\" id=\"schedule_sec_title\">\n          {lang === \"ru\" ? \"\320\230\320\275\321\202\320\265\321\200\320\260\320\272\321\202\320\270\320\262\320\275\320\276\320\265 \320\240\320\260\321\201\320\277\320\270\321\201\320\260\320\275\320\270\320\265\" : \"Interactive Program Schedule\"}\n        </h2>\n        <p className=\"mt-3 text-base text-slate-500\">\n          {lang === \"ru\" \n            ? \"\320\222\320\265\321\201\321\214 \320\264\320\265\320\275\321\214 \320\275\320\260\320\277\320\276\320\273\320\275\320\265\320\275 \320\277\321\200\320\260\320\272\321\202\320\270\321\207\320\265\321\201\320\272\320\270\320\274\320\270 \321\200\320\260\320\267\320\261\320\276\321\200\320\260\320\274\320\270, \320\266\320\270\320\262\321\213\320\274 \320\275\320\265\321\202\320\262\320\276\321\200\320\272\320\270\320\275\320\263\320\276\320\274 \320\270 \320\277\320\276\320\273\320\265\320\267\320\275\321\213\320\274\320\270 \321\201\320\265\321\201\321\201\320\270\321\217\320\274\320\270.\" \n            : \"A packed timeline of profile audits, writing workshops, and direct networking with Ivy League students.\"}\n        </p>\n      </div>\n\n      {/* Timeline Tree */}\n      <div className=\"relative border-l border-slate-100 pl-4 sm:pl-8 ml-2 sm:ml-6 space-y-6\" id=\"schedule_timeline_tree\">\n        {/* Sort program by schedule slots structure or return raw mapped items */}\n        {program.map((slot, index) => {\n          const isExpanded = !!expandedSlots[slot.id];\n          const speaker = findSpeaker(slot.speakerId);\n\n          return (\n            <div \n              key={slot.id} \n              className=\"relative group transition-all\"\n              id={`timeline_node_${slot.id}`}\n            >\n              {/* Vertical line connector badge node */}\n              <div \n                className={`absolute -left-[21px] sm:-left-[37px] top-1.5 flex h-8 w-8 items-center justify-center rounded-full border-2 bg-white transition duration-200 ${\n                  isExpanded \n                    ? \"border-sky-500 text-sky-500 shadow-sm\" \n                    : \"border-slate-200 text-slate-400 group-hover:border-slate-300\"\n                }`}\n                style={{ zIndex: 5 }}\n              >\n                <div className={`h-2.5 w-2.5 rounded-full ${isExpanded ? \"bg-sky-500\" : \"bg-slate-300 group-hover:bg-slate-400\"}`} />\n              </div>\n\n              {/* Main row card */}\n              <div className={`rounded-2xl border transition-all duration-300 p-5 ${\n                isExpanded \n                  ? \"border-slate-200/80 bg-slate-50/50 shadow-xs\" \n                  : \"border-slate-100 bg-white hover:border-slate-200 hover:shadow-xs\"\n              }`}>\n                {/* Clicking toggles the detail content */}\n                <div \n                  onClick={() => toggleSlot(slot.id)}\n                  className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-3 cursor-pointer select-none\"\n                  id={`slot_trigger_${slot.id}`}\n                >\n                  {/* Left Side: Time and Title */}\n                  <div className=\"flex items-start sm:items-center space-x-3 text-left\">\n                    <span className=\"flex items-center space-x-1 font-mono text-xs font-bold bg-white border border-slate-200 text-slate-600 rounded-lg px-2.5 py-1 flex-shrink-0\">\n                      <Clock className=\"h-3.5 w-3.5 text-slate-400\" />\n                      <span>{slot.time}</span>\n                    </span>\n                    <h3 className=\"text-base sm:text-lg font-bold text-slate-800 leading-tight group-hover:text-slate-900\">\n                      {lang === \"ru\" ? slot.title_ru : slot.title_en}\n                    </h3>\n                  </div>\n\n                  {/* Right Side: Indicators / Expand details toggle indicator */}\n                  <div className=\"flex items-center justify-between sm:justify-end gap-3 border-t sm:border-t-0 border-slate-100 pt-2 sm:pt-0\">\n                    {/* Speaker indicator tag */}\n                    {speaker && (\n                      <span \n                        onClick={(e) => {\n                          e.stopPropagation();\n                          scrollToSpeaker(speaker.id);\n                        }}\n                        className=\"inline-flex items-center space-x-1 rounded-full bg-sky-50 border border-sky-100 px-2.5 py-1 text-2xs font-extrabold text-sky-600 hover:bg-sky-100 transition\"\n                        title={lang === \"ru\" ? \"\320\237\320\276\321\201\320\274\320\276\321\202\321\200\320\265\321\202\321\214 \320\260\320\262\321\202\320\276\321\200\320\260\" : \"View Speaker Link\"}\n                      >\n                        <User className=\"h-3 w-3\" />\n                        <span>{lang === \"ru\" ? speaker.name_ru.split(\" \")[0] : speaker.name_en.split(\" \")[0]}</span>\n                      </span>\n                    )}\n\n                    <div className=\"text-slate-400 transition hover:text-slate-600\">\n                      {isExpanded ? <ChevronUp className=\"h-4 w-4\" /> : <ChevronDown className=\"h-4 w-4\" />}\n                    </div>\n                  </div>\n                </div>\n\n                {/* Expanded content */}\n                {isExpanded && (\n                  <div className=\"mt-4 border-t border-slate-100/80 pt-4 text-left animate-slide-down\">\n                    <p className=\"text-sm text-slate-600 leading-relaxed font-sans\">\n                      {lang === \"ru\" ? slot.description_ru : slot.description_en}\n                    </p>\n\n                    {/* Micro card of speaker inside the timeline description block */}\n                    {speaker && (\n                      <div className=\"mt-4 flex flex-col sm:flex-row items-start sm:items-center justify-between rounded-xl border border-slate-100 bg-white p-3.5 gap-3\">\n                        <div className=\"flex items-center space-x-3\">\n                          <div className=\"flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 border border-slate-200\">\n                            <span className=\"font-mono text-sm font-black text-slate-500\">\n                              {speaker.university.split(\" \")[0]}\n                            </span>\n                          </div>\n                          <div>\n                            <p className=\"text-xs font-black text-slate-800\">\n                              {lang === \"ru\" ? speaker.name_ru : speaker.name_en}\n                            </p>\n                            <p className=\"text-2xs font-bold text-slate-400\">\n                              {speaker.university} | {lang === \"ru\" ? speaker.major_ru : speaker.major_en}\n                            </p>\n                          </div>\n                        </div>\n\n                        <button \n                          onClick={() => scrollToSpeaker(speaker.id)}\n                          className=\"w-full sm:w-auto rounded-full bg-slate-900 px-4 py-1.5 text-2xs font-bold text-white hover:bg-slate-800 transition cursor-pointer text-center\"\n                        >\n                          {lang === \"ru\" ? \"\320\237\321\200\320\276\321\204\320\270\320\273\321\214 \320\241\320\277\320\270\320\272\320\265\321\200\320\260\" : \"View Story Bio\"}\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                )}\n              </div>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n"
    }
