        lines {
          text: "      \"story_ru\": \"\320\237\320\276\321\201\321\202\321\203\320\277\320\270\320\273\320\260 \320\262 \320\223\320\260\321\200\320\262\320\260\321\200\320\264 \320\277\320\276\321\201\320\273\320\265 \321\203\321\201\320\277\320\265\321\210\320\275\320\276\320\263\320\276 \320\277\321\200\320\265\320\276\320\264\320\276\320\273\320\265\320\275\320\270\321\217 \320\272\320\276\320\275\320\272\321\203\321\200\321\201\320\260 \321\201 \320\277\321\200\320\276\321\206\320\265\320\275\321\202\320\276\320\274 \320\277\321\200\320\270\320\265\320\274\320\260 <3%. \320\220\321\201\320\265\320\273\321\214 \321\200\320\260\320\267\321\200\320\260\320\261\320\276\321\202\320\260\320\273\320\260 \320\274\320\276\320\261\320\270\320\273\321\214\320\275\320\276\320\265 \320\277\321\200\320\270\320\273\320\276\320\266\320\265\320\275\320\270\320\265 \320\264\320\273\321\217 \320\277\320\276\320\264\320\263\320\276\321\202\320\276\320\262\320\272\320\270 \320\272 \320\225\320\235\320\242 \320\275\320\260 \320\272\320\260\320\267\320\260\321\205\321\201\320\272\320\276\320\274 \321\217\320\267\321\213\320\272\320\265, \321\207\321\202\320\276 \321\201\321\202\320\260\320\273\320\276 \320\262\320\260\320\266\320\275\321\213\320\274 \321\201\320\276\321\206\320\270\320\260\320\273\321\214\320\275\321\213\320\274 \320\277\321\200\320\276\320\265\320\272\321\202\320\276\320\274 (Social Impact) \320\262 \320\265\320\265 \320\260\320\275\320\272\320\265\321\202\320\265. \320\241\320\264\320\260\320\273\320\260 SAT \320\275\320\260 1560 \320\261\320\260\320\273\320\273\320\276\320\262, IELTS \320\275\320\260 8.5.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
