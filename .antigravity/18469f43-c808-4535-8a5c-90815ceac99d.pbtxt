    instruction: "Edit Hero component return statement to fit Clean Minimalism. Let theme be dominant white/slate-50 bg, clean border grids, sharp buttons, no glowing blurs, with gorgeous title layout."
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <section \n      id=\"hero\" \n      className=\"relative overflow-hidden bg-gradient-to-b from-sky-50/40 via-white to-white py-20 sm:py-28 lg:py-36 border-b border-slate-50\"\n    >\n      {/* Soft abstract graphic background circles */}\n      <div className=\"absolute top-1/4 left-1/10 h-72 w-72 rounded-full bg-sky-200/20 blur-3xl pointer-events-none\" />\n      <div className=\"absolute right-1/10 bottom-1/4 h-96 w-96 rounded-full bg-indigo-100/30 blur-3xl pointer-events-none\" />\n\n      <div className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center\">\n        {/* Top Minimal Pill Tag */}\n        <motion.div\n          initial={{ opacity: 0, y: -12 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.6 }}\n          className=\"inline-flex items-center space-x-1.5 rounded-full border border-sky-100 bg-sky-50/60 px-4 py-1.5 text-xs font-semibold text-sky-600 tracking-wide\"\n          id=\"hero_badge\"\n        >\n          <Award className=\"h-3 w-3\" />\n          <span>\n            {lang === \"ru\" \n              ? \"\320\223\320\233\320\220\320\222\320\235\320\236\320\225 \320\236\320\221\320\240\320\220\320\227\320\236\320\222\320\220\320\242\320\225\320\233\320\254\320\235\320\236\320\225 \320\241\320\236\320\221\320\253\320\242\320\230\320\225 \320\223\320\236\320\224\320\220\" \n              : \"THE MAIN EDUCATIONAL EVENT OF THE YEAR\"}\n          </span>\n        </motion.div>\n\n        {/* Massive Elegance Title */}\n        <motion.h1\n          initial={{ opacity: 0, y: 20 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.8, delay: 0.1 }}\n          className=\"mt-6 font-sans text-4xl font-black tracking-tight text-slate-900 sm:text-5xl md:text-6xl lg:text-7xl leading-tight sm:leading-none max-w-5xl mx-auto\"\n          id=\"hero_title\"\n        >\n          {lang === \"ru\" ? (\n            <>\n              \320\237\321\203\321\202\321\214 \320\262 \321\202\320\276\320\277-\320\262\321\203\320\267\321\213 \320\274\320\270\321\200\320\260: <br />\n              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-sky-500 via-sky-600 to-indigo-600\">\n                16+ \320\233\320\270\320\264\320\265\321\200\320\276\320\262 \320\233\320\270\320\263\320\270 \320\237\320\273\321\216\321\211\320\260\n              </span>\n            </>\n          ) : (\n            <>\n              Pathway to Top Global Ivy Colleges: <br />\n              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-sky-500 via-sky-600 to-indigo-600\">\n                17+ Admissions Experts\n              </span>\n            </>\n          )}\n        </motion.h1>\n\n        {/* Concise Description */}\n        <motion.p\n          initial={{ opacity: 0, y: 15 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.8, delay: 0.2 }}\n          className=\"mt-6 text-base sm:text-lg lg:text-xl text-slate-500 max-w-3xl mx-auto leading-relaxed\"\n          id=\"hero_desc\"\n        >\n          {lang === \"ru\" \n            ? \"\320\234\320\260\321\201\321\210\321\202\320\260\320\261\320\275\321\213\320\271 \321\204\320\276\321\200\321\203\320\274 \320\264\320\273\321\217 500 \321\203\321\207\320\260\321\201\321\202\320\275\320\270\320\272\320\276\320\262. \320\230\321\201\321\202\320\276\321\200\320\270\320\270 \321\203\321\201\320\277\320\265\321\205\320\260, \320\274\320\260\321\201\321\202\320\265\321\200-\320\272\320\273\320\260\321\201\321\201\321\213, \321\200\320\260\320\267\320\261\320\276\321\200\321\213 \321\215\321\201\321\201\320\265 \320\270 \321\201\320\265\320\272\321\200\320\265\321\202\321\213 \320\267\320\260\321\207\320\270\321\201\320\273\320\265\320\275\320\270\321\217 \320\275\320\260\320\277\321\200\321\217\320\274\321\203\321\216 \320\276\321\202 \321\201\321\202\321\203\320\264\320\265\320\275\321\202\320\276\320\262 \320\223\320\260\321\200\320\262\320\260\321\200\320\264\320\260, \320\241\321\202\321\215\320\275\321\204\320\276\321\200\320\264\320\260, \320\232\320\265\320\274\320\261\321\200\320\270\320\264\320\266\320\260, MIT \320\270 \320\235\320\260\320\267\320\260\321\200\320\261\320\260\320\265\320\262 \320\243\320\275\320\270\320\262\320\265\321\200\321\201\320\270\321\202\320\265\321\202\320\260.\"\n            : \"An immersive cohort event bringing representation from Harvard, Stanford, Cambridge, MIT, Caltech, and Nazarbayev University to Astana. Experience dynamic profile breakdowns and portfolio tuning.\"}\n        </motion.p>\n\n        {/* Venue / Date Information Ribbon */}\n        <motion.div\n          initial={{ opacity: 0, scale: 0.98 }}\n          animate={{ opacity: 1, scale: 1 }}\n          transition={{ duration: 0.7, delay: 0.3 }}\n          className=\"mt-10 mx-auto max-w-4xl rounded-2xl border border-slate-100 bg-white/70 shadow-sm shadow-slate-100/50 p-6 backdrop-blur-sm grid grid-cols-1 sm:grid-cols-3 gap-6 text-left\"\n          id=\"hero_details_ribbon\"\n        >\n          <div className=\"flex items-center space-x-3.5 sm:border-r border-slate-100/80 pr-4\">\n            <div className=\"rounded-xl bg-sky-50 p-2.5 text-sky-500\">\n              <Calendar className=\"h-5 w-5\" />\n            </div>\n            <div>\n              <p className=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">\n                {lang === \"ru\" ? \"\320\232\320\236\320\223\320\224\320\220\" : \"DATE\"}\n              </p>\n              <p className=\"text-sm font-bold text-slate-800 font-mono mt-0.5\">\n                {lang === \"ru\" ? \"26 \320\270\321\216\320\275\321\217, 2026\" : settings.eventDate}\n              </p>\n            </div>\n          </div>\n\n          <div className=\"flex items-center space-x-3.5 sm:border-r border-slate-100/80 pr-4 sm:pl-2\">\n            <div className=\"rounded-xl bg-emerald-50 p-2.5 text-emerald-500\">\n              <MapPin className=\"h-5 w-5\" />\n            </div>\n            <div>\n              <p className=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">\n                {lang === \"ru\" ? \"\320\223\320\224\320\225\" : \"VENUE\"}\n              </p>\n              <p className=\"text-sm font-bold text-slate-800 mt-0.5 leading-tight\">\n                {settings.eventVenue}\n              </p>\n            </div>\n          </div>\n\n          <div className=\"flex items-center space-x-3.5 sm:pl-2\">\n            <div className=\"rounded-xl bg-indigo-50 p-2.5 text-indigo-500\">\n              <Users className=\"h-5 w-5\" />\n            </div>\n            <div>\n              <p className=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">\n                {lang === \"ru\" ? \"\320\241\320\233\320\243\320\250\320\220\320\242\320\225\320\233\320\230\" : \"CAPACITY\"}\n              </p>\n              <p className=\"text-sm font-bold text-slate-800 mt-0.5\">\n                {lang === \"ru\" ? \"\320\236\320\263\321\200\320\260\320\275\320\270\321\207\320\265\320\275\320\270\320\265 \320\275\320\260 500 \321\207\320\265\320\273\320\276\320\262\320\265\320\272\" : \"Limited to 500 Seats\"}\n              </p>\n            </div>\n          </div>\n        </motion.div>\n\n        {/* CTA Actions */}\n        <motion.div\n          initial={{ opacity: 0, y: 15 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.8, delay: 0.4 }}\n          className=\"mt-10 flex flex-col sm:flex-row items-center justify-center gap-4\"\n          id=\"hero_actions\"\n        >\n          <button\n            onClick={() => scrollToSection(\"tickets\")}\n            className=\"w-full sm:w-auto rounded-full bg-slate-950 px-8 py-4 text-sm font-bold text-white tracking-wide shadow-lg shadow-slate-950/20 hover:bg-slate-800 hover:scale-101 active:scale-99 transition-all cursor-pointer\"\n            id=\"hero_btn_register\"\n          >\n            {lang === \"ru\" ? \"\320\227\320\260\320\261\321\200\320\276\320\275\320\270\321\200\320\276\320\262\320\260\321\202\321\214 \320\274\320\265\321\201\321\202\320\276\" : \"Secure Your Ticket\"}\n          </button>\n          <button\n            onClick={() => scrollToSection(\"speakers\")}\n            className=\"w-full sm:w-auto rounded-full border border-slate-200 bg-white px-8 py-4 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-slate-950 transition-all cursor-pointer\"\n            id=\"hero_btn_speakers\"\n          >\n            {lang === \"ru\" ? \"\320\237\320\276\321\201\320\274\320\276\321\202\321\200\320\265\321\202\321\214 \321\201\320\277\320\270\320\272\320\265\321\200\320\276\320\262\" : \"Explore Presenters\"}\n          </button>\n        </motion.div>"
        replacement_content: "  return (\n    <section \n      id=\"hero\" \n      className=\"relative overflow-hidden bg-[#F8FAFC] py-20 sm:py-28 lg:py-32 border-b border-slate-200\"\n    >\n      <div className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center\">\n        {/* Top Minimal Pill Tag */}\n        <motion.div\n          initial={{ opacity: 0, y: -12 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.6 }}\n          className=\"inline-flex items-center gap-3 px-4 py-2 bg-white border border-slate-200 shadow-xs mb-6 text-slate-800\"\n          id=\"hero_badge\"\n        >\n          <span className=\"flex h-2 w-2 rounded-full bg-blue-500 animate-pulse\"></span>\n          <span className=\"text-[10px] uppercase font-mono tracking-[0.2em] font-extrabold text-slate-500\">\n            {lang === \"ru\" \n              ? \"26 \320\230\320\256\320\235\320\257, 2026 \342\200\242 \320\220\320\241\320\242\320\220\320\235\320\220 \320\242\320\225\320\245\320\235\320\236\320\237\320\220\320\240\320\232\" \n              : \"JUNE 26, 2026 \342\200\242 TECHNOPARK CAMPUS\"}\n          </span>\n        </motion.div>\n\n        {/* Massive Elegance Title */}\n        <motion.h1\n          initial={{ opacity: 0, y: 20 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.8, delay: 0.1 }}\n          className=\"mt-6 font-display text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl md:text-6xl lg:text-[76px] lg:leading-[1.0] max-w-5xl mx-auto uppercase\"\n          id=\"hero_title\"\n        >\n          {lang === \"ru\" ? (\n            <>\n              \320\237\321\203\321\202\321\214 \320\262 \321\202\320\276\320\277-\320\262\321\203\320\267\321\213 \320\274\320\270\321\200\320\260<br/>\321\207\320\265\321\200\320\265\320\267 <span className=\"text-blue-500\">\320\273\320\270\320\263\321\203 \320\277\320\273\321\216\321\211\320\260.</span>\n            </>\n          ) : (\n            <>\n              The Future of<br/>Global <span className=\"text-blue-500\">Admissions.</span>\n            </>\n          )}\n        </motion.h1>\n\n        {/* Concise Description */}\n        <motion.p\n          initial={{ opacity: 0, y: 15 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.8, delay: 0.2 }}\n          className=\"mt-6 text-sm sm:text-base text-slate-600 max-w-2xl mx-auto leading-relaxed\"\n          id=\"hero_desc\"\n        >\n          {lang === \"ru\" \n            ? \"\320\234\320\260\321\201\321\210\321\202\320\260\320\261\320\275\321\213\320\271 \321\204\320\276\321\200\321\203\320\274 \320\264\320\273\321\217 500 \321\203\321\207\320\260\321\201\321\202\320\275\320\270\320\272\320\276\320\262. \320\230\321\201\321\202\320\276\321\200\320\270\320\270 \321\203\321\201\320\277\320\265\321\205\320\260, \320\274\320\260\321\201\321\202\320\265\321\200-\320\272\320\273\320\260\321\201\321\201\321\213, \321\200\320\260\320\267\320\261\320\276\321\200\321\213 \321\215\321\201\321\201\320\265 \320\270 \321\201\320\265\320\272\321\200\320\265\321\202\321\213 \320\267\320\260\321\207\320\270\321\201\320\273\320\265\320\275\320\270\321\217 \320\275\320\260\320\277\321\200\321\217\320\274\321\203\321\216 \320\276\321\202 \321\201\321\202\321\203\320\264\320\265\320\275\321\202\320\276\320\262 \320\223\320\260\321\200\320\262\320\260\321\200\320\264\320\260, \320\241\321\202\321\215\320\275\321\204\320\276\321\200\320\264\320\260, \320\232\320\265\320\274\320\261\321\200\320\270\320\264\320\266\320\260, MIT \320\270 \320\235\320\260\320\267\320\260\321\200\320\261\320\260\320\265\320\262 \320\243\320\275\320\270\320\262\320\265\321\200\321\201\320\270\321\202\320\265\321\202\320\260.\"\n            : \"An exclusive gathering of 500 visionaries featuring 16+ speakers from the world\'s most prestigious universities and tech hubs. Experience dynamic profile breakdowns and portfolio tuning.\"}\n        </motion.p>\n\n        {/* Venue / Date Information Ribbon */}\n        <motion.div\n          initial={{ opacity: 0, scale: 0.98 }}\n          animate={{ opacity: 1, scale: 1 }}\n          transition={{ duration: 0.7, delay: 0.3 }}\n          className=\"mt-12 mx-auto max-w-4xl border border-slate-200 bg-white grid grid-cols-1 sm:grid-cols-3 gap-0 text-left divide-y sm:divide-y-0 sm:divide-x divide-slate-200\"\n          id=\"hero_details_ribbon\"\n        >\n          <div className=\"flex flex-col justify-center p-8\">\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest font-mono\">\n              {lang === \"ru\" ? \"\320\232\320\236\320\223\320\224\320\220\" : \"DATE\"}\n            </span>\n            <span className=\"mt-1.5 text-lg font-black font-mono text-slate-900 leading-none\">\n              {lang === \"ru\" ? \"26 \320\270\321\216\320\275\321\217, 2026\" : settings.eventDate}\n            </span>\n          </div>\n\n          <div className=\"flex flex-col justify-center p-8\">\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest font-mono\">\n              {lang === \"ru\" ? \"\320\223\320\224\320\225\" : \"VENUE\"}\n            </span>\n            <span className=\"mt-1.5 text-sm font-extrabold text-[#3B82F6] leading-snug\">\n              {settings.eventVenue}\n            </span>\n          </div>\n\n          <div className=\"flex flex-col justify-center p-8 bg-slate-50/50\">\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest font-mono\">\n              {lang === \"ru\" ? \"\320\241\320\233\320\243\320\250\320\220\320\242\320\225\320\233\320\230\" : \"CAPACITY\"}\n            </span>\n            <span className=\"mt-1.5 text-sm font-extrabold text-slate-900 leading-snug\">\n              {lang === \"ru\" ? \"\320\236\320\263\321\200\320\260\320\275\320\270\321\207\320\265\320\275\320\270\320\265 \320\275\320\260 500 \320\274\320\265\321\201\321\202\" : \"Limited to 500 Seats\"}\n            </span>\n          </div>\n        </motion.div>\n\n        {/* CTA Actions */}\n        <motion.div\n          initial={{ opacity: 0, y: 15 }}\n          animate={{ opacity: 1, y: 0 }}\n          transition={{ duration: 0.8, delay: 0.4 }}\n          className=\"mt-10 flex flex-col sm:flex-row items-center justify-center gap-4\"\n          id=\"hero_actions\"\n        >\n          <button\n            onClick={() => scrollToSection(\"tickets\")}\n            className=\"w-full sm:w-auto bg-slate-900 px-8 py-4 text-xs font-bold uppercase tracking-widest text-white hover:bg-blue-500 transition-all cursor-pointer rounded-none duration-150\"\n            id=\"hero_btn_register\"\n          >\n            {lang === \"ru\" ? \"\320\227\320\260\320\261\321\200\320\276\320\275\320\270\321\200\320\276\320\262\320\260\321\202\321\214 \320\274\320\265\321\201\321\202\320\276\" : \"Secure Your Ticket\"}\n          </button>\n          <button\n            onClick={() => scrollToSection(\"speakers\")}\n            className=\"w-full sm:w-auto border border-slate-200 bg-white px-8 py-4 text-xs font-bold uppercase tracking-widest text-slate-700 hover:bg-slate-50 hover:border-slate-300 hover:text-slate-950 transition-all cursor-pointer rounded-none duration-150\"\n            id=\"hero_btn_speakers\"\n          >\n            {lang === \"ru\" ? \"\320\237\320\276\321\201\320\274\320\276\321\202\321\200\320\265\321\202\321\214 \321\201\320\277\320\270\320\272\320\265\321\200\320\276\320\262\" : \"Explore Presenters\"}\n          </button>\n        </motion.div>"
