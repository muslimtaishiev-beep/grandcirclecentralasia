    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"tickets_panel_container\">\n      {/* Intro Heading Section */}\n      <div className=\"text-center mb-12\">\n        <span className=\"rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-600 tracking-wider uppercase font-mono\">\n          {lang === \"ru\" ? \"\320\240\320\225\320\223\320\230\320\241\320\242\320\240\320\220\320\246\320\230\320\257\" : \"SECURE PASSES\"}\n        </span>\n        <h2 className=\"mt-3 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl\" id=\"tickets_sec_title\">\n          {lang === \"ru\" ? \"\320\222\321\213\320\261\320\265\321\200\320\270\321\202\320\265 \320\241\320\262\320\276\320\271 \320\244\320\276\321\200\320\274\320\260\321\202 \320\243\321\207\320\260\321\201\321\202\320\270\321\217\" : \"Seating and Admission Formats\"}\n        </h2>\n        <p className=\"mt-3 text-base text-slate-500 max-w-2xl mx-auto\">\n          {lang === \"ru\" \n            ? \"\320\224\320\276\321\201\321\202\321\203\320\277\320\275\321\213 \321\202\321\200\320\270 \320\272\320\260\321\202\320\265\320\263\320\276\321\200\320\270\320\270 \320\261\320\270\320\273\320\265\321\202\320\276\320\262. \320\222\321\213\320\261\320\265\321\200\320\270\321\202\320\265 \320\277\320\276\320\264\321\205\320\276\320\264\321\217\321\211\320\270\320\271 \321\203\321\200\320\276\320\262\320\265\320\275\321\214 \320\277\320\276\320\263\321\200\321\203\320\266\320\265\320\275\320\270\321\217 \320\270 \320\267\320\260\320\261\321\200\320\276\320\275\320\270\321\200\321\203\320\271\321\202\320\265 \320\274\320\265\321\201\321\202\320\276, \320\277\320\276\320\272\320\260 \320\261\320\270\320\273\320\265\321\202\321\213 \320\277\320\276 \321\202\320\265\320\272\321\203\321\211\320\265\320\271 \321\206\320\265\320\275\320\265 \320\265\321\201\321\202\321\214 \320\262 \320\275\320\260\320\273\320\270\321\207\320\270\320\270.\" \n            : \"Choose the level of feedback that fits your admissions goals. Prices will increase as our event capacity approaches maximum limits.\"}\n        </p>\n      </div>\n\n      {/* Pricing cards grid container */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch pt-4\" id=\"tickets_grid\">\n        {tickets.map((ticket) => {\n          // Check if it\'s the premium \'Business\' pass to highlight it\n          const isBusiness = ticket.id === \"t2\";\n          const isVip = ticket.id === \"t3\";\n          \n          return (\n            <div\n              key={ticket.id}\n              className={`relative flex flex-col justify-between rounded-3xl p-8 transition-all duration-300 ${\n                isBusiness \n                  ? \"border-2 border-sky-500 bg-white shadow-xl shadow-sky-500/5 ring-4 ring-sky-50/50 scale-102 z-10 md:-translate-y-2\" \n                  : \"border border-slate-100 bg-white/80 hover:border-slate-200 hover:shadow-lg\"\n              }`}\n              id={`ticket_card_${ticket.id}`}\n            >\n              {/* Highlight Ribbon for Business pass */}\n              {isBusiness && (\n                <span className=\"absolute -top-4 left-1/2 -translate-x-1/2 inline-flex items-center space-x-1 rounded-full bg-sky-500 px-4 py-1 text-2xs font-extrabold tracking-widest text-white uppercase shadow-md font-mono\">\n                  <Sparkles className=\"h-3 w-3 animate-pulse\" />\n                  <span>{lang === \"ru\" ? \"\320\237\320\276\320\277\321\203\320\273\321\217\321\200\320\275\321\213\320\271\" : \"RECOMMENDED\"}</span>\n                </span>\n              )}\n\n              {/* Box Top */}\n              <div>\n                <h3 className=\"text-lg font-bold text-slate-900\">\n                  {lang === \"ru\" ? ticket.name_ru : ticket.name_en}\n                </h3>\n                \n                {/* Price block */}\n                <div className=\"mt-4 flex items-baseline\">\n                  <span className=\"text-3xl font-black font-mono tracking-tight text-slate-900\">\n                    {ticket.price}\n                  </span>\n                  <span className=\"ml-1.5 text-xs font-semibold text-slate-400\">\n                    / {lang === \"ru\" ? \"\320\277\321\200\320\276\320\277\321\203\321\201\320\272\" : \"seat\"}\n                  </span>\n                </div>\n\n                {/* Benefits Bullet Checklist */}\n                <ul className=\"mt-8 space-y-4 border-t border-slate-50 pt-6\">\n                  {(lang === \"ru\" ? ticket.features_ru : ticket.features_en).map((feature, fIdx) => (\n                    <li key={fIdx} className=\"flex items-start space-x-3 text-left\">\n                      <div className={`mt-0.5 rounded-full p-0.5 flex-shrink-0 ${isBusiness ? \"bg-sky-500 text-white\" : \"bg-emerald-50 text-emerald-500\"}`}>\n                        <Check className=\"h-3.5 w-3.5\" />\n                      </div>\n                      <span className=\"text-xs sm:text-sm text-slate-600 font-medium leading-relaxed\">\n                        {feature}\n                      </span>\n                    </li>\n                  ))}\n                </ul>\n              </div>\n\n              {/* Outbound Booking CTA with custom UTM parameters concatenated string */}\n              <div className=\"mt-8 pt-4\">\n                <a\n                  href={buildUtmLink(ticket)}\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className={`flex w-full items-center justify-center space-x-2 rounded-full px-5 py-3.5 text-sm font-bold tracking-wide shadow-sm transition-all focus:outline-hidden ${\n                    isBusiness\n                      ? \"bg-sky-500 hover:bg-sky-600 text-white hover:shadow-md active:scale-98\"\n                      : isVip\n                      ? \"bg-slate-950 hover:bg-slate-800 text-white active:scale-98\"\n                      : \"bg-slate-50 border border-slate-200/60 hover:bg-slate-100 text-slate-700 active:scale-98\"\n                  }`}\n                  id={`cta_booking_link_${ticket.id}`}\n                >\n                  <span>{lang === \"ru\" ? \"\320\232\321\203\320\277\320\270\321\202\321\214 \320\261\320\270\320\273\320\265\321\202\" : \"Purchase Ticket\"}</span>\n                  <ArrowRight className=\"h-4 w-4\" />\n                </a>\n                \n                {/* Additional tracking parameters tiny diagnostic feedback link for user transparency */}\n                <p className=\"mt-3 text-center text-[10px] font-mono text-slate-400 font-medium tracking-2xs uppercase\">\n                  \342\255\220 {lang === \"ru\" ? \"\320\262\320\272\320\273\321\216\321\207\320\260\320\265\321\202 UTM \320\276\321\202\321\201\320\273\320\265\320\266\320\270\320\262\320\260\320\275\320\270\320\265\" : \"UTM attributes attached\"}\n                </p>\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Helpful Guarantee Tag line */}\n      <div className=\"mt-12 flex flex-col sm:flex-row items-center justify-center gap-4 text-center text-xs text-slate-400\">\n        <span className=\"flex items-center space-x-1.5 justify-center\">\n          <HelpCircle className=\"h-3.5 w-3.5 text-slate-300\" />\n          <span>{lang === \"ru\" ? \"\320\222\320\276\320\267\320\275\320\270\320\272\320\273\320\270 \320\262\320\276\320\277\321\200\320\276\321\201\321\213 \320\277\320\276 \320\276\320\277\320\273\320\260\321\202\320\265?\" : \"Trouble ordering online?\"}</span>\n        </span>\n        <span className=\"hidden sm:inline font-bold text-slate-200\">|</span>\n        <span>\n          {lang === \"ru\" \n            ? \"\320\241\320\262\321\217\320\266\320\270\321\202\320\265\321\201\321\214 \321\201 \320\276\321\200\320\263\320\260\320\275\320\270\320\267\320\260\321\202\320\276\321\200\320\260\320\274\320\270: info@mainedu.kz \320\270\320\273\320\270 +7 (7172) 55-44-33\" \n            : \"Direct support contact: info@mainedu.kz or +7 (7172) 55-44-33\"}\n        </span>\n      </div>\n    </div>"
        replacement_content: "  return (\n    <div className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"tickets_panel_container\">\n      {/* Intro Heading Section */}\n      <div className=\"text-center mb-12\">\n        <span className=\"border border-slate-200 bg-slate-100/30 px-3.5 py-1.5 text-2xs font-extrabold text-slate-500 tracking-widest uppercase font-mono\">\n          {lang === \"ru\" ? \"\320\240\320\225\320\223\320\230\320\241\320\242\320\240\320\220\320\246\320\230\320\257\" : \"SECURE PASSES\"}\n        </span>\n        <h2 className=\"mt-5 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl uppercase font-display\" id=\"tickets_sec_title\">\n          {lang === \"ru\" ? \"\320\242\320\220\320\240\320\230\320\244\320\253 \320\243\320\247\320\220\320\241\320\242\320\230\320\257\" : \"Seating and Admission Formats\"}\n        </h2>\n        <p className=\"mt-3 text-sm text-slate-500 max-w-2xl mx-auto leading-relaxed\">\n          {lang === \"ru\" \n            ? \"\320\224\320\276\321\201\321\202\321\203\320\277\320\275\321\213 \321\202\321\200\320\270 \320\272\320\260\321\202\320\265\320\263\320\276\321\200\320\270\320\270 \320\261\320\270\320\273\320\265\321\202\320\276\320\262. \320\222\321\213\320\261\320\265\321\200\320\270\321\202\320\265 \320\277\320\276\320\264\321\205\320\276\320\264\321\217\321\211\320\270\320\271 \321\203\321\200\320\276\320\262\320\265\320\275\321\214 \320\277\320\276\320\263\321\200\321\203\320\266\320\265\320\275\320\270\321\217 \320\270 \320\267\320\260\320\261\321\200\320\276\320\275\320\270\321\200\321\203\320\271\321\202\320\265 \320\274\320\265\321\201\321\202\320\276, \320\277\320\276\320\272\320\260 \320\261\320\270\320\273\320\265\321\202\321\213 \320\277\320\276 \321\202\320\265\320\272\321\203\321\211\320\265\320\271 \321\206\320\265\320\275\320\265 \320\265\321\201\321\202\321\214 \320\262 \320\275\320\260\320\273\320\270\321\207\320\270\320\270.\" \n            : \"Choose the level of feedback that fits your admissions goals. Prices will increase as our event capacity approaches maximum limits.\"}\n        </p>\n      </div>\n\n      {/* Pricing cards grid container */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch pt-4\" id=\"tickets_grid\">\n        {tickets.map((ticket) => {\n          // Check if it\'s the premium \'Business\' pass to highlight it\n          const isBusiness = ticket.id === \"t2\";\n          const isVip = ticket.id === \"t3\";\n          \n          return (\n            <div\n              key={ticket.id}\n              className={`relative flex flex-col justify-between p-8 transition-all duration-300 rounded-none ${\n                isBusiness \n                  ? \"border-2 border-blue-500 bg-white scale-100 z-10 md:-translate-y-1\" \n                  : \"border border-slate-200 bg-white hover:border-slate-300\"\n              }`}\n              id={`ticket_card_${ticket.id}`}\n            >\n              {/* Highlight Ribbon for Business pass */}\n              {isBusiness && (\n                <span className=\"absolute -top-3.5 left-1/2 -translate-x-1/2 inline-flex items-center space-x-1 border border-blue-500 bg-blue-500 px-4 py-1 text-[10px] font-bold tracking-widest text-white uppercase font-mono rounded-none\">\n                  <span>{lang === \"ru\" ? \"\320\240\320\225\320\232\320\236\320\234\320\225\320\235\320\224\320\243\320\225\320\234\" : \"RECOMMENDED\"}</span>\n                </span>\n              )}\n\n              {/* Box Top */}\n              <div>\n                <h3 className=\"text-sm font-extrabold uppercase tracking-widest text-slate-900 font-display\">\n                  {lang === \"ru\" ? ticket.name_ru : ticket.name_en}\n                </h3>\n                \n                {/* Price block */}\n                <div className=\"mt-4 flex items-baseline\">\n                  <span className=\"text-3xl font-black font-mono tracking-tight text-slate-900\">\n                    {ticket.price}\n                  </span>\n                  <span className=\"ml-1.5 text-2xs font-extrabold uppercase tracking-widest text-slate-400 font-mono\">\n                    / {lang === \"ru\" ? \"\320\277\321\200\320\276\320\277\321\203\321\201\320\272\" : \"seat\"}\n                  </span>\n                </div>\n\n                {/* Benefits Bullet Checklist */}\n                <ul className=\"mt-8 space-y-4 border-t border-slate-200 pt-6\">\n                  {(lang === \"ru\" ? ticket.features_ru : ticket.features_en).map((feature, fIdx) => (\n                    <li key={fIdx} className=\"flex items-start space-x-3 text-left\">\n                      <div className={`mt-1.5 rounded-none p-0.5 flex-shrink-0 ${isBusiness ? \"bg-blue-500 text-white\" : \"bg-slate-100 text-slate-700 border border-slate-200\"}`}>\n                        <Check className=\"h-3 w-3\" />\n                      </div>\n                      <span className=\"text-xs text-slate-600 font-medium leading-relaxed\">\n                        {feature}\n                      </span>\n                    </li>\n                  ))}\n                </ul>\n              </div>\n\n              {/* Outbound Booking CTA with custom UTM parameters concatenated string */}\n              <div className=\"mt-8 pt-4\">\n                <a\n                  href={buildUtmLink(ticket)}\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className={`flex w-full items-center justify-center space-x-2 px-5 py-4 text-xs font-bold uppercase tracking-widest transition-all duration-150 rounded-none cursor-pointer ${\n                    isBusiness\n                      ? \"bg-blue-500 hover:bg-slate-900 text-white\"\n                      : isVip\n                      ? \"bg-slate-900 hover:bg-blue-500 text-white\"\n                      : \"bg-white border border-slate-200 hover:bg-slate-55 flex hover:border-slate-350 text-s