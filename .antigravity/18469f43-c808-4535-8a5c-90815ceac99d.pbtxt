      >\n                  <Landmark className=\"h-6 w-6 text-sky-400 mb-2.5\" />\n                  <span className=\"text-base font-extrabold text-slate-800 tracking-tight\">{p.name}</span>\n                  <span className=\"text-3xs font-semibold text-slate-400 uppercase tracking-wider mt-1.5 font-mono\">\n                    {lang === \"ru\" ? p.role_ru : p.role_en}\n                  </span>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {/* Tier 2: Academic Sponsors / Leaders */}\n        {sponsors.length > 0 && (\n          <div className=\"space-y-4\" id=\"tier_sponsors\">\n            <h3 className=\"text-2xs font-extrabold text-indigo-400 uppercase tracking-widest font-mono\">\n              \342\234\246 {lang === \"ru\" ? \"\320\220\320\272\320\260\320\264\320\265\320\274\320\270\321\207\320\265\321\201\320\272\320\270\320\265 \321\201\320\277\320\276\320\275\321\201\320\276\321\200\321\213\" : \"Academic Language Sponsors\"} \342\234\246\n            </h3>\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto\">\n              {sponsors.map((p) => (\n                <div\n                  key={p.id}\n                  className=\"flex items-center space-x-4 rounded-xl border border-slate-100 bg-white p-5 text-left shadow-xs transition hover:border-slate-300 hover:shadow-xs\"\n                  id={`partner_${p.id}`}\n                >\n                  <div className=\"rounded-lg bg-indigo-50 p-2.5 text-indigo-500\">\n                    <Award className=\"h-5 w-5\" />\n                  </div>\n                  <div>\n                    <span className=\"block text-sm sm:text-base font-bold text-slate-800 tracking-tight\">{p.name}</span>\n                    <span className=\"text-4xs font-bold text-slate-400 uppercase tracking-wider font-mono\">\n                      {lang === \"ru\" ? p.role_ru : p.role_en}\n                    </span>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {/* Tier 3: Communication Partners / Media */}\n        {regular.length > 0 && (\n          <div className=\"space-y-4\" id=\"tier_regular\">\n            <h3 className=\"text-3xs font-extrabold text-slate-400 uppercase tracking-widest font-mono\">\n              {lang === \"ru\" ? \"\320\232\320\276\320\274\321\214\321\216\320\275\320\270\321\202\320\270 \320\270 \320\270\320\275\321\204\320\276\321\200\320\274\320\260\321\206\320\270\320\276\320\275\320\275\321\213\320\265 \320\277\320\260\321\200\321\202\320\275\320\265\321\200\321\213\" : \"Information Outreach & Support\"}\n            </h3>\n            <div className=\"flex justify-center flex-wrap gap-4 max-w-4xl mx-auto\">\n              {regular.map((p) => (\n                <div\n                  key={p.id}\n                  className=\"rounded-lg border border-slate-100 bg-white/70 px-4 py-2.5 text-xs font-semibold text-slate-500 hover:text-slate-800 transition hover:border-slate-200\"\n                  id={`partner_${p.id}`}\n                >\n                  <span className=\"font-mono text-3xs font-bold text-slate-300 mr-1.5\">#</span>\n                  <span>{p.name}</span>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n      </div>\n    </div>"
