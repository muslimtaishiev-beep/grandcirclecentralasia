    replacement_chunks {
      replacement_content: "{\n  \"settings\": {\n    \"eventDate\": \"June 26, 2026\",\n    \"eventVenue\": \"Astana Technopark, Block C4\",\n    \"adminPassword\": \"admin\",\n    \"contactEmail\": \"info@mainedu.kz\",\n    \"contactPhone\": \"+7 (7172) 55-44-33\"\n  },\n  \"speakers\": [\n    {\n      \"id\": \"1\",\n      \"name_ru\": \"\320\220\321\201\320\265\320\273\321\214 \320\220\320\273\320\270\320\274\320\266\320\260\320\275\320\276\320\262\320\260\",\n      \"name_en\": \"Asel Alimzhanova\",\n      \"university\": \"Harvard University\",\n      \"major_ru\": \"\320\232\320\276\320\274\320\277\321\214\321\216\321\202\320\265\321\200\320\275\321\213\320\265 \320\235\320\260\321\203\320\272\320\270 (Computer Science)\",\n      \"major_en\": \"Computer Science\",\n      \"admissionYear\": \"Class of 2027\",\n      \"story_ru\": \"\320\237\320\276\321\201\321\202\321\203\320\277\320\270\320\273\320\260 \320\262 \320\223\320\260\321\200\320\262\320\260\321\200\320\264 \320\277\320\276\321\201\320\273\320\265 \321\203\321\201\320\277\320\265\321\210\320\275\320\276\320\263\320\276 \320\277\321\200\320\265\320\276\320\264\320\276\320\273\320\265\320\275\320\270\321\217 \320\272\320\276\320\275\320\272\321\203\321\200\321\201\320\260 \321\201 \320\277\321\200\320\276\321\206\320\265\320\275\321\202\320\276\320\274 \320\277\321\200\320\270\320\265\320\274\320\260 <3%. \320\220\321\201\320\265\320\273\321\214 \321\200\320\260\320\267\321\200\320\260\320\261\320\276\321\202\320\260\320\273\320\260 \320\274\320\276\320\261\320\270\320\273\321\214\320\275\320\276\320\265 \320\277\321\200\320\270\320\273\320\276\320\266\320\265\320\275\320\270\320\265 \320\264\320\273\321\217 \320\277\320\276\320\264\320\263\320\276\321\202\320\276\320\262\320\272\320\270 \320\272 \320\225\320\235\320\242 \320\275\320\260 \320\272\320\260\320\267\320\260\321\205\321\201\320\272\320\276\320\274 \321\217\320\267\321\213\320\272\320\265, \321\207\321\202\320\276 \321\201\321\202\320\260\320\273\320\276 \320\262\320\260\320\266\320\275\321\213\320\274 \321\201\320\276\321\206\320\270\320\260\320\273\321\214\320\275\321\213\320\274 \320\277\321\200\320\276\320\265\320\272\321\202\320\276\320\274 (Social Impact) \320\262 \320\265\320\265 \320\260\320\275\320\272\320\265\321\202\320\265. \320\241\320\264\320\260\320\273\320\260 SAT \320\275\320\260 1560 \320\261\320\260\320\273\320\273\320\276\320\262, IELTS \320\275\320\260 8.5.\",\n      \"story_en\": \"Admitted to Harvard with an acceptance rate under 3%. Asel developed a mobile app for Kazakh university entrance prep, which served as a major social impact project in her application. She scored 1560 on the SAT and 8.5 on the IELTS.\",\n      \"lectureTopic_ru\": \"\320\241\321\202\321\200\320\260\321\202\320\265\320\263\320\270\321\217 \320\233\320\270\321\207\320\275\320\276\320\263\320\276 \320\221\321\200\320\265\320\275\320\264\320\260: \320\232\320\260\320\272 \320\275\320\260\320\277\320\270\321\201\320\260\321\202\321\214 \321\215\321\201\321\201\320\265 \320\264\320\273\321\217 \320\233\320\270\320\263\320\270 \320\237\320\273\321\216\321\211\320\260\",\n      \"lectureTopic_en\": \"Personal Branding Strategy: Crafting Ivy League Essays That Stand Out\",\n      \"lectureTime\": \"10:30 am\",\n      \"colorTheme\": \"blue\",\n      \"isFeatured\": true\n    },\n    {\n      \"id\": \"2\",\n      \"name_ru\": \"\320\240\320\260\320\271\320\263\321\203\320\273\321\214 \320\220\321\205\320\274\320\265\321\202\320\276\320\262\320\260\",\n      \"name_en\": \"Raygul Akhmetova\",\n      \"university\": \"Stanford University\",\n      \"major_ru\": \"\320\241\320\270\320\274\320\262\320\276\320\273\320\270\321\207\320\265\321\201\320\272\320\270\320\265 \320\241\320\270\321\201\321\202\320\265\320\274\321\213 (Symbolic Systems)\",\n      \"major_en\": \"Symbolic Systems\",\n      \"admissionYear\": \"Class of 2028\",\n      \"story_ru\": \"\320\237\320\276\320\273\321\203\321\207\320\270\320\273\320\260 \320\277\320\276\320\273\320\275\321\203\321\216 \321\201\321\202\320\270\320\277\320\265\320\275\320\264\320\270\321\216 \320\262 \320\241\321\202\321\215\320\275\321\204\320\276\321\200\320\264\320\265, \320\276\320\261\321\212\320\265\320\264\320\270\320\275\321\217\321\217 \320\267\320\275\320\260\320\275\320\270\321\217 \320\262 \320\276\320\261\320\273\320\260\321\201\321\202\320\270 \320\273\320\270\320\275\320\263\320\262\320\270\321\201\321\202\320\270\320\272\320\270, \320\275\320\265\320\271\321\200\320\276\320\275\320\260\321\203\320\272 \320\270 \320\277\321\200\320\276\320\263\321\200\320\260\320\274\320\274\320\270\321\200\320\276\320\262\320\260\320\275\320\270\321\217. \320\236\321\201\320\275\320\276\320\262\320\260\321\202\320\265\320\273\321\214\320\275\320\270\321\206\320\260 \320\264\320\265\320\261\320\260\321\202\320\275\320\276\320\263\320\276 \320\272\320\273\321\203\320\261\320\260 \320\270 \320\277\321\200\320\270\320\267\320\265\321\200 \320\274\320\265\320\266\320\264\321\203\320\275\320\260\321\200\320\276\320\264\320\275\321\213\321\205 \320\276\320\273\320\270\320\274\320\277\320\270\320\260\320\264 \320\277\320\276 \320\273\320\270\320\275\320\263\320\262\320\270\321\201\321\202\320\270\320\272\320\265.\",\n      \"story_en\": \"Awarded a full ride at Stanford, bridging linguistics, neuroscience, and computer science. She is the founder of a regional debate league and a prize winner in international linguistics olympiads.\",\n      \"lectureTopic_ru\": \"\320\232\320\260\320\272 \320\276\320\261\321\212\320\265\320\264\320\270\320\275\320\270\321\202\321\214 \321\200\320\260\320\267\320\275\321\213\320\265 \320\270\320\275\321\202\320\265\321\200\320\265\321\201\321\213 \320\262 \321\201\320\270\320\273\321\214\320\275\321\213\320\271 \320\274\320\265\320\266\320\264\320\270\321\201\321\206\320\270\320\277\320\273\320\270\320\275\320\260\321\200\320\275\321\213\320\271 \320\277\321\200\320\276\321\204\320\270\320\273\321\214\",\n      \"lectureTopic_en\": \"Interdisciplinary Focus: Blending Tech & Humanities in a Stanford Application\",\n      \"lectureTime\": \"11:15 am\",\n      \"colorTheme\": \"purple\",\n      \"isFeatured\": true\n    },\n    {\n      \"id\": \"3\",\n      \"name_ru\": \"\320\224\320\260\320\275\320\270\320\260\320\273 \320\241\320\265\321\200\320\270\320\272\320\276\320\262\",\n      \"name_en\": \"Danial Serikov\",\n      \"university\": \"MIT\",\n      \"major_ru\": \"\320\244\320\270\320\267\320\270\320\272\320\260 \320\270 \320\232\320\262\320\260\320\275\321\202\320\276\320\262\321\213\320\265 \320\222\321\213\321\207\320\270\321\201\320\273\320\265\320\275\320\270\321\217\",\n      \"major_en\": \"Physics & Quantum Computing\",\n      \"admissionYear\": \"Class of 2026\",\n      \"story_ru\": \"\320\237\320\276\320\261\320\265\320\264\320\270\321\202\320\265\320\273\321\214 \320\234\320\265\320\266\320\264\321\203\320\275\320\260\321\200\320\276\320\264\320\275\320\276\320\271 \321\204\320\270\320\267\320\270\321\207\320\265\321\201\320\272\320\276\320\271 \320\276\320\273\320\270\320\274\320\277\320\270\320\260\320\264\321\213 (IPhO), \320\260\320\262\321\202\320\276\321\200 \320\264\320\262\321\203\321\205 \320\275\320\260\321\203\321\207\320\275\321\213\321\205 \321\201\321\202\320\260\321\202\320\265\320\271 \320\277\320\276 \320\272\320\262\320\260\320\275\321\202\320\276\320\262\320\276\320\271 \320\274\320\265\321\205\320\260\320\275\320\270\320\272\320\265. \320\224\320\260\320\275\320\270\320\260\320\273 \320\277\320\276\320\264\320\265\320\273\320\270\321\202\321\201\321\217 \321\202\320\265\320\274, \320\275\320\260\321\201\320\272\320\276\320\273\321\214\320\272\320\276 \320\262\320\260\320\266\320\275\321\213 \320\276\320\273\320\270\320\274\320\277\320\270\320\271\321\201\320\272\320\270\320\265 \320\264\320\276\321\201\321\202\320\270\320\266\320\265\320\275\320\270\321\217 \320\264\320\273\321\217 \320\277\320\276\321\201\321\202\321\203\320\277\320\273\320\265\320\275\320\270\321\217 \320\262 \321\202\320\276\320\277-3 \321\202\320\265\321\205\320\275\320\276\320\273\320\276\320\263\320\270\321\207\320\265\321\201\320\272\320\270\321\205 \320\262\321\203\320\267\320\260 \320\274\320\270\321\200\320\260.\",\n      \"story_en\": \"International Physics Olympiad (IPhO) gold medalist and developer of quantum simulation models. Danial will discuss the weight of olympiad metrics in securing top-3 STEM admissions.\",\n      \"lectureTopic_ru\": \"\320\236\320\273\320\270\320\274\320\277\320\270\320\260\320\264\321\213 vs \320\230\321\201\321\201\320\273\320\265\320\264\320\276\320\262\320\260\321\202\320\265\320\273\321\214\321\201\320\272\320\270\320\265 \320\277\321\200\320\276\320\265\320\272\321\202\321\213: \320\222\320\267\320\263\320\273\321\217\320\264 \320\270\320\267 MIT\",\n      \"lectureTopic_en\": \"Olympiads vs Research Projects: A Strategy Guide from MIT\",\n      \"lectureTime\": \"12:00 pm\",\n      \"colorTheme\": \"rose\",\n      \"isFeatured\": true\n    },\n    {\n      \"id\": \"4\",\n      \"name_ru\": \"\320\227\320\260\321\200\320\270\320\275\320\260 \320\225\321\201\320\270\320\274\320\276\320\262\320\260\",\n      \"name_en\": \"Zarina Yesimova\",\n      \"university\": \"Columbia University\",\n      \"major_ru\": \"\320\255\320\272\320\276\320\275\320\276\320\274\320\270\320\272\320\260 \320\270 \320\221\320\270\320\267\320\275\320\265\321\201-\320\260\320\275\320\260\320\273\320\270\321\202\320\270\320\272\320\260\",\n      \"major_en\": \"Economics & Business Analytics\",\n      \"admissionYear\": \"Class of 2027\",\n      \"story_ru\": \"\320\237\321\200\320\276\320\262\320\265\320\273\320\260 \320\275\320\265\320\267\320\260\320\262\320\270\321\201\320\270\320\274\320\276\320\265 \320\270\321\201\321\201\320\273\320\265\320\264\320\276\320\262\320\260\320\275\320\270\320\265 \320\262\320\273\320\270\321\217\320\275\320\270\321\217 \320\270\320\275\321\204\320\273\321\217\321\206\320\270\320\270 \320\275\320\260 \320\274\320\260\320\273\321\213\320\271 \320\261\320\270\320\267\320\275\320\265\321\201 \320\262 \321\200\320\265\320\263\320\270\320\276\320\275\320\260\321\205 \320\232\320\260\320\267\320\260\321\205\321\201\321\202\320\260\320\275\320\260. \320\237\321\200\320\276\321\210\320\273\320\260 \321\201\321\202\320\260\320\266\320\270\321\200\320\276\320\262\320\272\321\203 \320\262 Big Four \320\270 \320\262\320\265\320\273\320\260 \320\261\320\273\320\276\320\263 \320\277\320\276 \321\204\320\270\320\275\320\260\320\275\321\201\320\276\320\262\320\276\320\271 \320\263\321\200\320\260\320\274\320\276\321\202\320\275\320\276\321\201\321\202\320\270 \320\264\320\273\321\217 \320\277\320\276\320\264\321\200\320\276\321\201\321\202\320\272\320\276\320\262.\",\n      \"story_en\": \"Published research assessing inflation rates on rural micro-businesses. Secured an early internship at a Big Four firm and hosted financial literacy workshops for local youth.\",\n      \"lectureTopic_ru\": \"\320\230\321\201\321\201\320\273\320\265\320\264\320\276\320\262\320\260\321\202\320\265\320\273\321\214\321\201\320\272\320\260\321\217 \321\200\320\260\320\261\320\276\321\202\320\260 \321\210\320\272\320\276\320\273\321\214\320\275\320\270\320\272\320\260: \320\236\321\202 \320\270\320\264\320\265\320\270 \320\264\320\276 \320\277\321\203\320\261\320\273\320\270\320\272\320\260\321\206\320\270\320\270\",\n      \"lectureTopic_en\": \"High School Research: From Raw Idea to Academic Publication\",\n      \"lectureTime\": \"02:00 pm\",\n      \"colorTheme\": \"cyan\",\n      \"isFeatured\": true\n    },\n    {\n      \"id\": \"5\",\n      \"name_ru\": \"\320\220\320\264\320\270\320\273\321\214 \320\242\321\203\321\200\321\201\321\203\320\275\320\276\320\262\",\n      \"name_en\": \"Adil Tursunov\",\n      \"university\": \"University of Oxford\",\n      \"major_ru\": \"\320\244\320\270\320\273\320\276\321\201\320\276\321\204\320\270\321\217, \320\237\320\276\320\273\320\270\321\202\320\270\320\272\320\260, \320\255\320\272\320\276\320\275\320\276\320\274\320\270\320\272\320\260 (PPE)\",\n      \"major_en\": \"Philosophy, Politics & Economics (PPE)\",\n      \"admissionYear\": \"Class of 2027\",\n      \"story_ru\": \"\320\237\321\200\320\276\321\210\320\265\320\273 \321\201\320\273\320\276\320\266\320\275\320\265\320\271\321\210\320\270\320\265 \320\277\320\270\321\201\321\214\320\274\320\265\320\275\320\275\321\213\320\265 \321\202\320\265\321\201\321\202\321\213 \320\236\320\272\321\201\321\204\320\276\321\200\320\264\320\260 TSA \320\270 \320\264\320\262\320\260 \321\202\321\203\321\200\320\260 \321\203\321\201\321\202\320\275\321\213\321\205 \320\270\320\275\321\202\320\265\321\200\320\262\321\214\321\216 \321\201 \320\277\321\200\320\276\321\204\320\265\321\201\321\201\320\276\321\200\320\260\320\274\320\270. \320\241\320\277\320\265\321\206\320\270\320\260\320\273\320\270\320\267\320\270\321\200\321\203\320\265\321\202\321\201\321\217 \320\275\320\260 \320\263\320\276\321\201\321\203\320\264\320\260\321\200\321\201\321\202\320\262\320\265\320\275\320\275\320\276\320\274 \321\203\320\277\321\200\320\260\320\262\320\273\320\265\320\275\320\270\320\270 \320\270 \321\215\321\202\320\270\320\272\320\265 \320\230\320\230.\",\n      \"story_en\": \"Scored in the top percentile of Oxford\'s TSA exam and cleared three rounds of rigorous Oxbridge tutorial style interviews. Passionate about public policy and AI ethics.\",\n      \"lectureTopic_ru\": \"\320\230\320\275\321\202\320\265\321\200\320\262\321\214\321\216 \320\262 \320\236\320\272\321\201\321\204\320\276\321\200\320\264 \320\270 \320\232\320\265\320\274\320\261\321\200\320\270\320\264\320\266: \320\230\321\201\320\272\321\203\321\201\321\201\321\202\320\262\320\276 \320\274\321\213\321\201\320\273\320\270\321\202\321\214 \320\262\321\201\320\273\321\203\321\205\",\n      \"lectureTopic_en\": \"Oxbridge Interviews: Deconstructing Academic Thinking Live\",\n      \"lectureTime\": \"02:45 pm\",\n      \"colorTheme\": \"indigo\",\n      \"isFeatured\": true\n    },\n    {\n      \"id\": \"6\",\n      \"name_ru\": \"\320\232\320\260\320\274\320\270\320\273\320\260 \320\221\320\260\320\271\321\201\320\265\320\270\321\202\320\276\320\262\320\260\",\n      \"name_en\": \"Kamila Baiseitova\",\n      \"university\": \"Nazarbayev University\",\n      \"major_ru\": \"\320\245\320\270\320\274\320\270\321\207\320\265\321\201\320\272\320\260\321\217 \320\270\320\275\320\266\320\265\320\275\320\265\321\200\320\270\321\217\",\n      \"major_en\": \"Chemical Engineering\",\n      \"admissionYear\": \"Class of 2026\",\n      \"story_ru\": \"\320\222\320\265\320\264\321\203\321\211\320\270\320\271 \320\270\321\201\321\201\320\273\320\265\320\264\320\276\320\262\320\260\321\202\320\265\320\273\321\214 \320\273\320\260\320\261\320\260\321\200\320\260\321\202\320\276\321\200\320\270\320\270 \320\267\320\265\320\273\320\265\320\275\321\213\321\205 \321\202\320\265\321\205\320\275\320\276\320\273\320\276\320\263\320\270\320\271, \320\276\320\261\320\273\320\260\320\264\320\260\321\202\320\265\320\273\321\214\320\275\320\270\321\206\320\260 \320\263\321\200\320\260\320\275\321\202\320\260 \320\275\320\260 \321\201\321\202\320\260\320\266\320\270\321\200\320\276\320\262\320\272\321\203 \320\262 \320\223\320\265\321\200\320\274\320\260\320\275\320\270\320\270. \320\232\320\260\320\274\320\270\320\273\320\260 \321\200\320\260\321\201\321\201\320\272\320\260\320\266\320\265\321\202 \320\276 \321\201\320\270\320\273\320\265 \320\272\320\276\320\274\321\214\321\216\320\275\320\270\321\202\320\270 \320\235\320\260\320\267\320\260\321\200\320\261\320\260\320\265\320\262 \320\243\320\275\320\270\320\262\320\265\321\200\321\201\320\270\321\202\320\265\321\202\320\260 \320\270 \320\277\321\203\321\202\321\217\321\205 \320\262\321\213\321\205\320\276\320\264\320\260 \320\275\320\260 \320\274\320\265\320\266\320\264\321\203\320\275\320\260\321\200\320\276\320\264\320\275\321\203\321\216 \320\260\321\200\320\265\320\275\321\203.\",\n      \"story_en\": \"Lead student researcher in renewable solutions and recipient of a German DAAD chemical engineering fellowship. Kamila talks about NU\'s local facilities and pathway to EU research labs.\",\n      \"lectureTopic_ru\": \"\320\220\320\272\320\260\320\264\320\265\320\274\320\270\321\207\320\265\321\201\320\272\320\270\320\265 \320\262\320\276\320\267\320\274\320\276\320\266\320\275\320\276\321\201\321\202\320\270 \320\262 NU: \320\232\320\260\320\272 \321\203\320\265\321\205\320\260\321\202\321\214 \320\275\320\260 \321\201\321\202\320\260\320\266\320\270\321\200\320\276\320\262\320\272\321\203 \320\267\320\260 \321\200\321\203\320\261\320\265\320\266\",\n      \"lectureTopic_en\": \"Unlocking NU Academic Power: Fully Funded Global Research Internships\",\n      \"lectureTime\": \"03:30 pm\",\n      \"colorTheme\": \"teal\",\n      \"isFeatured\": false\n    },\n    {\n      \"id\": \"7\",\n      \"name_ru\": \"\320\220\320\273\320\270\321\210\320\265\321\200 \320\236\320\274\320\260\321\200\320\276\320\262\",\n      \"name_en\": \"Alisher Omarov\",\n      \"university\": \"Yale University\",\n      \"major_ru\": \"\320\230\321\201\321\202\320\276\321\200\320\270\321\217 \320\270 \320\234\320\265\320\266\320\264\321\203\320\275\320\260\321\200\320\276\320\264\320\275\321\213\320\265 \320\236\321\202\320\275\320\276\321\210\320\265\320\275\320\270\321\217\",\n      \"major_en\": \"History & International Relations\",\n      \"admissionYear\": \"Class of 2028\",\n      \"story_ru\": \"\320\220\320\262\321\202\320\276\321\200 \320\261\320\273\320\276\320\263\320\260 \320\276\320\261 \320\270\321\201\321\202\320\276\321\200\320\270\320\270 \320\246\320\265\320\275\321\202\321\200\320\260\320\273\321\214\320\275\320\276\320\271 \320\220\320\267\320\270\320\270 \321\201 30 \321\202\321\213\321\201. \320\277\320\276\320\264\320\277\320\270\321\201\321\207\320\270\320\272\320\276\320\262. \320\237\321\200\320\265\320\267\320\270\320\264\320\265\320\275\321\202 \320\274\320\276\320\264\320\265\320\273\320\270 \320\236\320\236\320\235 (MUN), \320\276\321\200\320\263\320\260\320\275\320\270\320\267\320\276\320\262\320\260\320\262\321\210\320\270\320\271 \320\272\320\276\320\275\321\204\320\265\321\200\320\265\320\275\321\206\320\270\321\216 \320\264\320\273\321\217 600 \321\210\320\272\320\276\320\273\321\214\320\275\320\270\320\272\320\276\320\262.\",\n      \"story_en\": \"Author of a popular Central Asian historical archive blog with 30k followers. Organized a multi-city MUN conference accommodating 600 students.\",\n      \"lectureTopic_ru\": \"\320\222\320\275\320\265\320\272\320\273\320\260\321\201\321\201\320\275\320\260\321\217 \320\264\320\265\321\217\321\202\320\265\320\273\321\214\320\275\320\276\321\201\321\202\321\214 (Extracurriculars): \320\232\320\260\320\272 \321\203\320\271\321\202\320\270 \320\276\321\202 \320\272\320\273\320\270\321\210\320\265\",\n      \"lectureTopic_en\": \"Extracurricular Profiles: Stepping Beyond the Standard Resume\",\n      \"lectureTime\": \"04:15 pm\",\n      \"colorTheme\": \"amber\",\n      \"isFeatured\": false\n    },\n    {\n      \"id\": \"8\",\n      \"name_ru\": \"\320\234\320\265\321\200\321\203\320\265\321\200\321\202 \320\232\320\260\320\271\321\200\320\260\321\202\320\276\320\262\320\260\",\n      \"name_en\": \"Meruert Kairatova\",\n      \"university\": \"Princeton University\",\n      \"major_ru\": \"\320\234\320\260\321\202\320\265\320\274\320\260\321\202\320\270\320\272\320\260 (Mathematics)\",\n      \"major_en\": \"Mathematics\",\n      \"admissionYear\": \"Class of 2027\",\n      \"story_ru\": \"\320\237\321\200\320\270\320\267\320\265\321\200 \320\225\320\262\321\200\320\276\320\277\320\265\320\271\321\201\320\272\320\276\320\271 \320\264\320\265\320\262\320\270\321\207\321\214\320\265\320\271 \320\274\320\260\321\202\320\265\320\274\320\260\321\202\320\270\321\207\320\265\321\201\320\272\320\276\320\271 \320\276\320\273\320\270\320\274\320\277\320\270\320\260\320\264\321\213 (EGMO). \320\234\320\265\321\200\321\203\320\265\321\200\321\202 \321\200\320\260\320\267\321\200\321\203\321\210\320\270\321\202 \321\201\321\202\320\265\321\200\320\265\320\276\321\202\320\270\320\277\321\213 \320\276 \320\274\320\260\321\202\320\265\320\274\320\260\321\202\320\270\320\272\320\260\321\205 \320\270 \321\200\320\260\321\201\321\201\320\272\320\260\320\266\320\265\321\202 \320\276 \320\272\321\200\320\265\320\260\321\202\320\270\320\262\320\275\320\276\321\201\321\202\320\270 \320\262 \321\202\320\276\321\207\320\275\321\213\321\205 \320\275\320\260\321\203\320\272\320\260\321\205.\",\n      \"story_en\": \"Silver Medalist at the European Girls\' Mathematical Olympiad (EGMO). Meruert deconstructs math application profiling and shares her creative focus on abstract theory.\",\n      \"lectureTopic_ru\": \"\320\226\320\265\320\275\321\211\320\270\320\275\321\213 \320\262 STEM: \320\237\321\203\321\202\321\214 \320\262 \320\237\321\200\320\270\320\275\321\201\321\202\320\276\320\275 \320\270 \320\276\320\273\320\270\320\274\320\277\320\270\320\260\320\264\320\275\320\260\321\217 \320\272\320\260\321\200\321\214\320\265\321\200\320\260\",\n      \"lectureTopic_en\": \"Women in STEM: Navigating Math Olympiads to Princeton Admissions\",\n      \"lectureTime\": \"05:00 pm\",\n      \"colorTheme\": \"orange\",\n      \"isFeatured\": false\n    },\n    {\n      \"id\": \"9\",\n      \"name_ru\": \"\320\241\321\203\320\273\321\202\320\260\320\275\320\261\320\265\320\272 \320\221\320\265\320\272\320\265\321\202\320\276\320\262\",\n      \"name_en\": \"Sultanbek Beketov\",\n      \"university\": \"University of Cambridge\",\n      \"major_ru\": \"\320\230\320\275\320\266\320\265\320\275\320\265\321\200\320\270\321\217 (Engineering)\",\n      \"major_en\": \"Engineering\",\n      \"admissionYear\": \"Class of 2026\",\n      \"story_ru\": \"\320\236\320\261\321\203\