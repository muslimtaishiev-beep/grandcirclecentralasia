t-semibold text-slate-500 uppercase tracking-wider font-mono\">\n                    {lang === \"ru\" ? \"\320\237\320\276\320\273\320\275\321\213\320\271 \320\224\320\265\320\275\321\214\" : \"Intense Day\"}\n                  </span>\n                  <p className=\"mt-1.5 text-2xs text-slate-400\">From 09:30 am to 06:00 pm</p>\n                </div>\n\n                <div className=\"rounded-2xl border border-slate-100 bg-linear-to-b from-emerald-50/20 to-white hover:border-slate-200/80 p-6 text-left shadow-xs\">\n                  <span className=\"block text-4xl font-black font-mono tracking-tight text-slate-900\">100%</span>\n                  <span className=\"mt-2 block text-xs font-semibold text-slate-500 uppercase tracking-wider font-mono\">\n                    {lang === \"ru\" ? \"\320\240\320\265\320\260\320\273\321\214\320\275\321\213\320\271 \320\236\320\277\321\213\321\202\" : \"Practical Focus\"}\n                  </span>\n                  <p className=\"mt-1.5 text-2xs text-slate-400\">Live essay tuning and evaluations</p>\n                </div>\n              </div>\n            </section>\n\n            {/* SPEAKERS SECTION */}\n            <section className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"speakers\">\n              <div className=\"text-left mb-12 sm:mb-16\">\n                <span className=\"rounded-full bg-sky-50 px-3 py-1 text-xs font-bold text-sky-600 tracking-wider uppercase font-mono\">\n                  {lang === \"ru\" ? \"\320\237\320\240\320\230\320\223\320\233\320\220\320\250\320\225\320\235\320\235\320\253\320\225 \320\233\320\225\320\232\320\242\320\236\320\240\320\253\" : \"REPRESENTING ELITE ACADEMIA\"}\n                </span>\n                <h2 className=\"mt-3 font-display text-3xl font-black tracking-tight text-slate-900 sm:text-4xl\">\n                  {lang === \"ru\" \n                    ? \"\320\221\320\276\320\273\320\265\320\265 16 \320\241\320\277\320\270\320\272\320\265\321\200\320\276\320\