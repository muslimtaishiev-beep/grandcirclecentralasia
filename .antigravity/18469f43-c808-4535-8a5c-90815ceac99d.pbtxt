          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    .then(blob => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const blobUrl = window.URL.createObjectURL(blob);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
