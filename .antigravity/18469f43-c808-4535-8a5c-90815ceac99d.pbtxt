      target_content: "  return (\n    <div className=\"mx-auto max-w-4xl rounded-3xl border border-slate-100 bg-linear-to-b from-sky-50/20 to-white hover:border-slate-200/80 p-8 sm:p-12 text-center relative overflow-hidden\" id=\"newsletter_container\">\n      {/* Background soft circle blur decor */}\n      <div className=\"absolute -bottom-16 -right-16 h-36 w-36 rounded-full bg-sky-200/20 blur-2xl pointer-events-none\" />\n\n      {status === \"success\" ? (\n        // SUCCESS CARD FEEDBACK Layout\n        <div className=\"space-y-6 py-6 animate-scale-up\" id=\"subscribe_success_view\">\n          <div className=\"mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-emerald-50 text-emerald-500 border border-emerald-100\">\n            <CheckCircle className=\"h-7 w-7\" />\n          </div>\n          <div>\n            <h3 className=\"text-xl sm:text-2xl font-black text-slate-800 tracking-tight\">\n              {lang === \"ru\" ? \"\320\237\320\276\320\267\320\264\321\200\320\260\320\262\320\273\321\217\320\265\320\274! \320\222\321\213 \320\267\320\260\321\200\320\265\320\263\320\270\321\201\321\202\321\200\320\270\321\200\320\276\320\262\320\260\320\273\320\270\321\201\321\214\" : \"Thank You, Registration Logged\"}\n            </h3>\n            <p className=\"mt-3 text-sm text-slate-500 max-w-md mx-auto leading-relaxed\">\n              {lang === \"ru\" \n                ? \"\320\224\320\260\320\275\320\275\321\213\320\265 \321\203\321\201\320\277\320\265\321\210\320\275\320\276 \320\264\320\276\320\261\320\260\320\262\320\273\320\265\320\275\321\213 \320\262 \320\265\320\264\320\270\320\275\321\203\321\216 \320\261\320\260\320\267\321\203. \320\234\321\213 \320\276\321\202\320\277\321\200\320\260\320\262\320\270\320\274 \320\262\320\260\320\274 \320\277\321\200\320\270\320\276\321\200\320\270\321\202\320\265\321\202\320\275\321\213\320\265 \320\274\320\260\321\202\320\265\321\200\320\270\320\260\320\273\321\213 \321\204\320\276\321\200\321\203\320\274\320\260 \320\270 \320\263\320\260\320\271\320\264 \320\277\320\276 \320\277\320\276\321\201\321\202\321\203\320\277\320\273\320\265\320\275\320\270\321\216 \320\275\320\260 \321\203\320\272\320\260\320\267\320\260\320\275\320\275\321\203\321\216 \321\215\320\273\320\265\320\272\321\202\321\200\320\276\320\275\320\275\321\203\321\216 \320\277\320\276\321\207\321\202\321\203!\" \n                : \"Your details are locked. Expect confirmation notices, Ivy League workbook packets, and schedule updates directly in your mailbox!\"}\n            </p>\n          </div>\n          <button\n            onClick={() => setStatus(\"idle\")}\n            className=\"rounded-full bg-slate-950 px-6 py-2.5 text-xs font-bold text-white hover:bg-slate-800 transition cursor-pointer\"\n            id=\"btn_subscribe_reset\"\n          >\n            {lang === \"ru\" ? \"\320\227\320\260\321\200\320\265\320\263\320\270\321\201\321\202\321\200\320\270\321\200\320\276\320\262\320\260\321\202\321\214 \320\267\320\260\320\275\320\276\320\262\320\276\" : \"Log Another Address\"}\n          </button>\n        </div>\n      ) : (\n        // RAW INPUT FORM Layout\n        <div className=\"space-y-6\" id=\"subscribe_form_layout\">\n          <div>\n            <span className=\"rounded-full bg-sky-50 px-3 py-1 text-xs font-bold text-sky-600 tracking-wider uppercase font-mono\">\n              {lang === \"ru\" ? \"\320\240\320\220\320\241\320\241\320\253\320\233\320\232\320\220 / \320\223\320\220\320\231\320\224\" : \"NEWSLETTER REGISTRATION\"}\n            </span>\n            <h2 className=\"mt-3 text-2xl font-black text-slate-800 tracking-tight sm:text-3xl\">\n              {lang === \"ru\" ? \"\320\237\321\200\320\270\321\201\320\276\320\265\320\264\320\270\320\275\321\217\320\271\321\202\320\265\321\201\321\214 \320\272 \320\261\320\260\320\267\320\265 \321\204\320\276\321\200\321\203\320\274\320\260\" : \"Unlock Admissions Intelligence\"}\n            </h2>\n            <p className=\"mt-2.5 text-xs sm:text-sm text-slate-400 max-w-lg mx-auto\">\n              {lang === \"ru\" \n                ? \"\320\227\320\260\321\200\320\265\320\263\320\270\321\201\321\202\321\200\320\270\321\200\321\203\320\271\321\202\320\265\321\201\321\214, \321\207\321\202\320\276\320\261\321\213 \321\201\320\272\320\260\321\207\320\260\321\202\321\214 \320\277\320\276\320\264\321\200\320\276\320\261\320\275\321\213\320\271 PDF-\320\263\320\260\320\271\320\264 \320\277\320\276 \320\275\320\260\320\277\320\270\321\201\320\260\320\275\320\270\321\216 \321\215\321\201\321\201\320\265 \320\276\321\202 \320\275\320\260\321\210\320\270\321\205 \321\201\320\277\320\270\320\272\320\265\321\200\320\276\320\262 \320\270 \320\277\320\276\320\273\321\203\321\207\320\260\321\202\321\214 \321\203\320\262\320\265\320\264\320\276\320\274\320\273\320\265\320\275\320\270\321\217 \320\276 \321\202\321\200\320\260\320\275\321\201\321\204\320\265\321\200\320\265.\" \n                : \"Register early to receive the 2026 Ivy League Essay Prompt Guide compilations compiled by our 17 admitted presenters.\"}\n            </p>\n          </div>\n\n          {/* Form */}\n          <form onSubmit={handleSubscribe} className=\"mt-8 max-w-2xl mx-auto space-y-4 text-left\" id=\"subscription_form\">\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n              {/* Name field */}\n              <div className=\"relative\">\n                <label className=\"block text-4xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1 font-mono\">\n                  {lang === \"ru\" ? \"\320\222\320\260\321\210\320\265 \320\230\320\274\321\217 *\" : \"Your Name *\"}\n                </label>\n                <div className=\"relative\">\n                  <User className=\"absolute top-3.5 left-4 h-4 w-4 text-slate-400\" />\n                  <input\n                    type=\"text\"\n                    required\n                    value={name}\n                    onChange={(e) => setName(e.target.value)}\n                    placeholder={lang === \"ru\" ? \"\320\220\321\201\320\265\320\273\321\214 \320\220.\" : \"Asel A.\"}\n                    className=\"w-full rounded-2xl border border-slate-100 bg-white/60 p-3 pl-11 text-xs sm:text-sm font-semibold text-slate-700 outline-hidden transition focus:border-sky-500 focus:bg-white focus:ring-3 focus:ring-sky-100/50\"\n                    id=\"input_sub_name\"\n                  />\n                </div>\n              </div>\n\n              {/* Phone field */}\n              <div className=\"relative\">\n                <label className=\"block text-4xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1 font-mono\">\n                  {lang === \"ru\" ? \"\320\242\320\265\320\273\320\265\321\204\320\276\320\275 (\320\235\320\265\320\276\320\261\321\217\320\267\320\260\321\202\320\265\320\273\321\214\320\275\320\276)\" : \"Phone (Optional)\"}\n                </label>\n                <div className=\"relative\">\n                  <Phone className=\"absolute top-3.5 left-4 h-4 w-4 text-slate-400\" />\n                  <input\n                    type=\"tel\"\n                    value={phone}\n                    onChange={(e) => setPhone(e.target.value)}\n                    placeholder=\"+7 (777) 123-4567\"\n                    className=\"w-full rounded-2xl border border-slate-100 bg-white/60 p-3 pl-11 text-xs sm:text-sm font-semibold text-slate-700 outline-hidden transition focus:border-sky-500 focus:bg-white focus:ring-3 focus:ring-sky-100/50\"\n                    id=\"input_sub_phone\"\n                  />\n                </div>\n              </div>\n            </div>\n\n            {/* Email field */}\n            <div className=\"relative\">\n              <label className=\"block text-4xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1 font-mono\">\n                {lang === \"ru\" ? \"\320\255\320\273\320\265\320\272\321\202\321\200\320\276\320\275\320\275\320\260\321\217 \320\277\320\276\321\207\321\202\320\260 *\" : \"Email Address *\"}\n              </label>\n              <div className=\"relative\">\n                <Mail className=\"absolute top-3.5 left-4 h-4 w-4 text-slate-400\" />\n                <input\n                  type=\"email\"\n                  required\n                  value={email}\n                  onChange={(e) => setEmail(e.target.value)}\n                  placeholder=\"asel@gmail.com\"\n                  className=\"w-full rounded-2xl border border-slate-100 bg-white/60 p-3 pl-11 text-xs sm:text-sm font-semibold text-slate-700 outline-hidden transition focus:border-sky-500 focus:bg-white focus:ring-3 focus:ring-sky-100/50\"\n                  id=\"input_sub_email\"\n                />\n              </div>\n            </div>\n\n            {/* Diagnostic warning / error state feedback banner */}\n            {status === \"error\" && (\n              <div className=\"rounded-xl border border-red-100 bg-red-50 p-4 flex items-start space-x-3 text-left max-w-2xl mx-auto animate-shake\" id=\"sub_error_banner\">\n                <AlertCircle className=\"h-5 w-5 text-red-500 mt-0.5 flex-shrink-0\" />\n                <p className=\"text-xs font-bold text-red-600\">{message}</p>\n              </div>\n            )}\n\n            {/* Submission triggers */}\n            <div className=\"pt-2\">\n              <button\n                type=\"submit\"\n                disabled={status === \"loading\"}\n                className=\"w-full rounded-full bg-slate-950 px-6 py-4 text-xs sm:text-sm font-black tracking-widest text-white uppercase shadow-md hover:bg-slate-800 disabled:bg-slate-400 hover:scale-101 active:scale-99 transition-all flex items-center justify-center space-x-2 cursor-pointer\"\n                id=\"btn_submit_newsletter\"\n              >\n                {status === \"loading\" ? (\n                  <>\n                    <Loader2 className=\"h-4 w-4 animate-spin text-white\" />\n                    <span>{lang === \"ru\" ? \"\320\236\320\242\320\237\320\240\320\220\320\222\320\232\320\220...\" : \"LOGGING DETAILS...\"}</span>\n                  </>\n                ) : (\n                  <span>{lang === \"ru\" ? \"\320\245\320\236\320\247\320\243 \320\237\320\236\320\233\320\243\320\247\320\230\320\242\320\254 PDF-\320\223\320\220\320\231\320\224 && \320\240\320\220\320\241\320\241\320\253\320\233\320\232\320\243\" : \"REGISTER FOR UPDATES & PDF GUIDE\"}</span>\n                )}\n              </button>\n            </div>\n          </form>\n        </div>\n      )}\n    </div>\n  );\n}"
      replacement_content: "  return (\n    <div className=\"mx-auto max-w-4xl border border-slate-200 bg-white p-8 sm:p-12 text-center relative overflow-hidden rounded-none\" id=\"newsletter_container\">\n      {status === \"success\" ? (\n        // SUCCESS CARD FEEDBACK Layout\n        <div className=\"space-y-6 py-6 animate-scale-up\" id=\"subscribe_success_view\">\n          <div className=\"mx-auto flex h-14 w-14 items-center justify-center rounded-none bg-emerald-50 text-emerald-500 border border-emerald-250\">\n            <CheckCircle className=\"h-7 w-7\" />\n          </div>\n          <div>\n            <h3 className=\"text-xl sm:text-2xl font-black text-slate-900 tracking-tight uppercase font-display\">\n              {lang === \"ru\" ? \"\320\237\320\276\320\267\320\264\321\200\320\260\320\262\320\273\321\217\320\265\320\274! \320\222\321\213 \320\267\320\260\321\200\320\265\320\263\320\270\321\201\321\202\321\200\320\270\321\200\320\276\320\262\320\260\320\273\320\270\321\201\321\214\" : \"Thank You, Registration Logged\"}\n            </h3>\n            <p className=\"mt-3 text-sm text-slate-500 max-w-md mx-auto leading-relaxed font-sans\">\n              {lang === \"ru\" \n                ? \"\320\224\320\260\320\275\320\275\321\213\320\265 \321\203\321\201\320\277\320\265\321\210\320\275\320\276 \320\264\320\276\320\261\320\260\320\262\320\273\320\265\320\275\321\213 \320\262 \320\265\320\264\320\270\320\275\321\203\321\216 \320\261\320\260\320\267\321\203. \320\234\321\213 \320\276\321\202\320\277\321\200\320\260\320\262\320\270\320\274 \320\262\320\260\320\274 \320\277\321\200\320\270\320\276\321\200\320\270\321\202\320\265\321\202\320\275\321\213\320\265 \320\274\320\260\321\202\320\265\321\200\320\270\320\260\320\273\321\213 \321\204\320\276\321\200\321\203\320\274\320\260 \320\270 \320\263\320\260\320\271\320\264 \320\277\320\276 \320\277\320\276\321\201\321\202\321\203\320\277\320\273\320\265\320\275\320\270\321\216 \320\275\320\260 \321\203\