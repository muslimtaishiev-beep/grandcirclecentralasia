        lines {
          text: "      \"story_ru\": \"\320\237\320\276\320\273\321\203\321\207\320\270\320\273\320\260 \320\277\320\276\320\273\320\275\321\203\321\216 \321\201\321\202\320\270\320\277\320\265\320\275\320\264\320\270\321\216 \320\262 \320\241\321\202\321\215\320\275\321\204\320\276\321\200\320\264\320\265, \320\276\320\261\321\212\320\265\320\264\320\270\320\275\321\217\321\217 \320\267\320\275\320\260\320\275\320\270\321\217 \320\262 \320\276\320\261\320\273\320\260\321\201\321\202\320\270 \320\273\320\270\320\275\320\263\320\262\320\270\321\201\321\202\320\270\320\272\320\270, \320\275\320\265\320\271\321\200\320\276\320\275\320\260\321\203\320\272 \320\270 \320\277\321\200\320\276\320\263\321\200\320\260\320\274\320\274\320\270\321\200\320\276\320\262\320\260\320\275\320\270\321\217. \320\236\321\201\320\275\320\276\320\262\320\260\321\202\320\265\320\273\321\214\320\275\320\270\321\206\320\260 \320\264\320\265\320\261\320\260\321\202\320\275\320\276\320\263\320\276 \320\272\320\273\321\203\320\261\320\260 \320\270 \320\277\321\200\320\270\320\267\320\265\321\200 \320\274\320\265\320\266\320\264\321\203\320\275\320\260\321\200\320\276\320\264\320\275\321\213\321\205 \320\276\320\273\320\270\320\274\320\277\320\270\320\260\320\264 \320\277\320\276 \320\273\320\270\320\275\320\263\320\262\320\270\321\201\321\202\320\270\320\272\320\265.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \"story_en\": \"Awarded a full ride at Stanford, bridging linguistics, neuroscience, and computer science. She is the founder of a regional debate league and a prize winner in international linguistics olympiads.\","
