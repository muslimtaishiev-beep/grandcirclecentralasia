    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \"react\";\nimport { \n  Award, Globe, Landmark, Clock, ArrowRight, Sparkles, HelpCircle, GraduationCap, Phone, Mail, \n  MapPin, Loader2, ChevronRight, CheckCircle2, ShieldAlert\n} from \"lucide-react\";\n\n// Components\nimport Header from \"./components/Header\";\nimport Hero from \"./components/Hero\";\nimport SpeakerCard from \"./components/SpeakerCard\";\nimport SchedulePanel from \"./components/SchedulePanel\";\nimport TicketsPanel from \"./components/TicketsPanel\";\nimport PartnersPanel from \"./components/PartnersPanel\";\nimport Newsletter from \"./components/Newsletter\";\nimport AdminCMS from \"./components/AdminCMS\";\n\nimport { PublicData } from \"./types\";\n\nexport default function App() {\n  const [lang, setLang] = useState<\"ru\" | \"en\">(\"ru\");\n  const [isAdminOpen, setIsAdminOpen] = useState(false);\n  const [loading, setLoading] = useState(true);\n  const [dataTrigger, setDataTrigger] = useState(0);\n\n  // Core public information state\n  const [publicData, setPublicData] = useState<PublicData | null>(null);\n\n  // Fetch all database metrics from backend\n  useEffect(() => {\n    const fetchPublicData = async () => {\n      try {\n        const response = await fetch(\"/api/public/data\");\n        if (response.ok) {\n          const resJson = await response.json();\n          setPublicData(resJson);\n        }\n      } catch (err) {\n        console.error(\"Failed to load global server resources.\", err);\n      } finally {\n        setLoading(false);\n      }\n    };\n\n    fetchPublicData();\n  }, [dataTrigger]);\n\n  const forceRefetch = () => {\n    setDataTrigger(prev => prev + 1);\n  };\n\n  // Loading skeleton layout\n  if (loading) {\n    return (\n      <div className=\"flex min-h-screen flex-col items-center justify-center bg-slate-50/50 space-y-4\" id=\"global_loader\">\n        <Loader2 className=\"h-10 w-10 animate-spin text-sky-400\" />\n        <p className=\"text-xs font-bold text-slate-400 uppercase tracking-widest font-mono\">\n          Assembling Forum Workspace...\n        </p>\n      </div>\n    );\n  }\n\n  // Fallback state if server returns empty\n  const data = publicData || {\n    settings: {\n      eventDate: \"June 26, 2026\",\n      eventVenue: \"Astana Technopark, Block C4\",\n      contactPhone: \"+7 (7172) 55-44-33\",\n      contactEmail: \"info@mainedu.kz\"\n    },\n    speakers: [],\n    program: [],\n    partners: [],\n    tickets: []\n  };\n\n  const featuredSpeakers = data.speakers.filter(s => s.isFeatured);\n  const normalSpeakers = data.speakers.filter(s => !s.isFeatured);\n\n  return (\n    <div className=\"min-h-screen bg-white text-slate-700 antialiased font-sans flex flex-col justify-between selection:bg-sky-100 selection:text-sky-950\" id=\"main_app_wrapper\">\n      \n      {/* 1. Header Navigation and lang switcher */}\n      <Header \n        lang={lang} \n        setLang={setLang} \n        isAdminOpen={isAdminOpen} \n        setIsAdminOpen={setIsAdminOpen} \n      />\n\n      {/* 2. Main Page content panels */}\n      <main className=\"flex-grow\">\n        {isAdminOpen ? (\n          /* ADMINISTRATIVE CMS CONSOLE VIEW */\n          <div className=\"bg-slate-50/30 min-h-[75vh] animate-fade-in\" id=\"admin_cms_panel_wrapper\">\n            <AdminCMS lang={lang} onDataChange={forceRefetch} />\n          </div>\n        ) : (\n          /* STANDARD PUBLIC VISITOR LANDING VIEW */\n          <div className=\"space-y-24 sm:space-y-32 pb-24\" id=\"visitor_landing_wrapper\">\n            \n            {/* HERO SECTION */}\n            <Hero lang={lang} settings={data.settings} />\n\n            {/* KEY METRICS BENTO GRID */}\n            <section className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"stats_metrics_section\">\n              <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6\">\n                <div className=\"rounded-2xl border border-slate-100 bg-linear-to-b from-sky-50/20 to-white hover:border-slate-200/80 p-6 text-left shadow-xs\">\n                  <span className=\"block text-4xl font-black font-mono tracking-tight text-slate-900\">500+</span>\n                  <span className=\"mt-2 block text-xs font-semibold text-slate-500 uppercase tracking-wider font-mono\">\n                    {lang === \"ru\" ? \"\320\243\321\207\320\260\321\201\321\202\320\275\320\270\320\272\320\276\320\262\" : \"Live Attendees\"}\n                  </span>\n                  <p className=\"mt-1.5 text-2xs text-slate-400\">Astana Technopark scale limits</p>\n                </div>\n                \n                <div className=\"rounded-2xl border border-slate-100 bg-linear-to-b from-purple-50/20 to-white hover:border-slate-200/80 p-6 text-left shadow-xs\">\n                  <span className=\"block text-4xl font-black font-mono tracking-tight text-slate-900\">16+</span>\n                  <span className=\"mt-2 block text-xs font-semibold text-slate-500 uppercase tracking-wider font-mono\">\n                    {lang === \"ru\" ? \"\320\242\320\276\320\277-\321\201\320\276\320\262\320\265\321\202\320\275\320\270\320\272\320\276\320\262\" : \"Ivy Advisers\"}\n                  </span>\n                  <p className=\"mt-1.5 text-2xs text-slate-400\">Harvard, Stanford, Oxford, Cambridge</p>\n                </div>\n\n                <div className=\"rounded-2xl border border-slate-100 bg-linear-to-b from-rose-50/20 to-white hover:border-slate-200/80 p-6 text-left shadow-xs\">\n                  <span className=\"block text-4xl font-black font-mono tracking-tight text-slate-900\">1</span>\n                  <span className=\"mt-2 block text-xs font-semibold text-slate-500 uppercase tracking-wider font-mono\">\n                    {lang === \"ru\" ? \"\320\237\320\276\320\273\320\275\321\213\320\271 \320\224\320\265\320\275\321\214\" : \"Intense Day\"}\n                  </span>\n                  <p className=\"mt-1.5 text-2xs text-slate-400\">From 09:30 am to 06:00 pm</p>\n                </div>\n\n                <div className=\"rounded-2xl border border-slate-100 bg-linear-to-b from-emerald-50/20 to-white hover:border-slate-200/80 p-6 text-left shadow-xs\">\n                  <span className=\"block text-4xl font-black font-mono tracking-tight text-slate-900\">100%</span>\n                  <span className=\"mt-2 block text-xs font-semibold text-slate-500 uppercase tracking-wider font-mono\">\n                    {lang === \"ru\" ? \"\320\240\320\265\320\260\320\273\321\214\320\275\321\213\320\271 \320\236\320\277\321\213\321\202\" : \"Practical Focus\"}\n                  </span>\n                  <p className=\"mt-1.5 text-2xs text-slate-400\">Live essay tuning and evaluations</p>\n                </div>\n              </div>\n            </section>\n\n            {/* SPEAKERS SECTION */}\n            <section className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"speakers\">\n              <div className=\"text-left mb-12 sm:mb-16\">\n                <span className=\"rounded-full bg-sky-50 px-3 py-1 text-xs font-bold text-sky-600 tracking-wider uppercase font-mono\">\n                  {lang === \"ru\" ? \"\320\237\320\240\320\230\320\223\320\233\320\220\320\250\320\225\320\235\320\235\320\253\320\225 \320\233\320\225\320\232\320\242\320\236\320\240\320\253\" : \"REPRESENTING ELITE ACADEMIA\"}\n                </span>\n                <h2 className=\"mt-3 font-display text-3xl font-black tracking-tight text-slate-900 sm:text-4xl\">\n                  {lang === \"ru\" \n                    ? \"\320\221\320\276\320\273\320\265\320\265 16 \320\241\320\277\320\270\320\272\320\265\321\200\320\276\320\262 \320\270\320\267 \320\233\321\203\321\207\321\210\320\270\321\205 \320\243\320\275\320\270\320\262\320\265\321\200\321\201\320\270\321\202\320\265\321\202\320\276\320\262\" \n                    : \"Meet Your Ivy & Global Admissions Advisers\"}\n                </h2>\n                <p className=\"mt-4 text-base text-slate-500 max-w-3xl leading-relaxed\">\n                  {lang === \"ru\"\n                    ? \"\320\235\320\260\321\210\320\270 \320\273\320\265\320\272\321\202\320\276\321\200\321\213 \342\200\224 \320\275\320\265 \320\277\321\200\320\276\321\201\321\202\320\276 \321\202\320\265\320\276\321\200\320\265\321\202\320\270\320\272\320\270, \320\260 \320\272\320\260\320\267\320\260\321\205\321\201\321\202\320\260\320\275\321\201\320\272\320\270\320\265 \321\201\321\202\321\203\320\264\320\265\320\275\321\202\321\213, \321\203\321\201\320\277\320\265\321\210\320\275\320\276 \320\277\321\200\320\276\321\210\320\265\320\264\321\210\320\270\320\265 \320\276\321\202\320\261\320\276\321\200 \320\262 \321\202\320\276\320\277-\320\262\321\203\320\267\321\213 \320\233\320\270\320\263\320\270 \320\237\320\273\321\216\321\211\320\260 \320\270 \320\274\320\270\321\200\320\260. \320\232\320\273\320\270\320\272\320\275\320\270\321\202\320\265 \320\275\320\260 \320\272\320\260\321\200\321\202\320\276\321\207\320\272\321\203 \321\201\320\277\320\270\320\272\320\265\321\200\320\260, \321\207\321\202\320\276\320\261\321\213 \321\203\320\267\320\275\320\260\321\202\321\214 \320\264\320\265\321\202\320\260\320\273\320\270 \320\277\321\200\320\265\320\267\320\265\320\275\321\202\320\260\321\206\320\270\320\270.\"\n                    : \"These are real-world high achievers, sharing their portfolios, standardized score tactics, and actual application essays. Click any presenter card to check details.\"}\n                </p>\n              </div>\n\n              {/* 1. Feature Speakers Grid */}\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8\" id=\"featured_speakers_grid\">\n                {featuredSpeakers.map(speaker => (\n                  <SpeakerCard key={speaker.id} speaker={speaker} lang={lang} />\n                ))}\n              </div>\n\n              {/* 2. Standard Speakers Grid */}\n              {normalSpeakers.length > 0 && (\n                <div className=\"mt-12 sm:mt-16 border-t border-slate-100 pt-12 text-left\">\n                  <h3 className=\"text-sm font-black text-slate-400 uppercase tracking-widest font-mono mb-8\">\n                    {lang === \"ru\" ? \"\320\222\321\201\320\265 \321\201\320\277\320\270\320\272\320\265\321\200\321\213 \320\270 \320\272\320\276\320\275\321\201\321\203\320\273\321\214\321\202\320\260\320\275\321\202\321\213\" : \"Additional Admissions Consultants\"}\n                  </h3>\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8\" id=\"all_speakers_list\">\n                    {normalSpeakers.map(speaker => (\n                      <SpeakerCard key={speaker.id} speaker={speaker} lang={lang} />\n                    ))}\n                  </div>\n                </div>\n              )}\n            </section>\n\n            {/* TIMELINE SECTION */}\n            <section className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"schedule\">\n              <SchedulePanel program={data.program} speakers={data.speakers} lang={lang} />\n            </section>\n\n            {/* TICKETS SECTION */}\n            <section className=\"bg-slate-50/40 py-20 border-y border-slate-100/60\" id=\"tickets\">\n              <TicketsPanel tickets={data.tickets} lang={lang} />\n            </section>\n\n            {/* PARTNERS SECTION */}\n            <section className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"partners\">\n              <PartnersPanel partners={data.partners} lang={lang} />\n            </section>\n\n            {/* NEWSLETTER CAPTURE */}\n            <section className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\" id=\"newsletter\">\n              <Newsletter lang={lang} />\n            </section>\n\n          </div>\n        )}\n      </main>\n\n      {/* 3. Footer Branding Area */}\n      <footer className=\"border-t border-slate-100 bg-white py-12\" id=\"footer_container\">\n        <div className=\"mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8 space-y-6\">\n          \n          <div className=\"flex flex-col sm:flex-row items-center justify-between border-b border-slate-100 pb-8 gap-4\">\n            <div className=\"flex items-center space-x-2 text-slate-900 text-left\">\n              <Sparkles className=\"h-5 w-5 text-sky-400\" />\n              <div>\n                <span className=\"block font-sans font-extrabold tracking-tight text-slate-800 text-sm\">\n                  THE MAIN EDUCATIONAL EVENT OF THE YEAR\n                </span>\n                <span className=\"block text-[10px] text-slate-400 uppercase font-mono font-bold tracking-wider mt-0.5\">\n                  Hosted inside Astana Technopark \342\200\242 June 26, 2026\n                </span>\n              </div>\n            </div>\n\n            {/* Outbound Contacts display */}\n            <div className=\"flex flex-wrap items-center gap-4 text-xs font-semibold text-slate-500 font-mono\">\n              <a href={`mailto:${data.settings.contactEmail}`} className=\"hover:text-sky-500 flex items-center space-x-1\">\n                <Mail className=\"h-4 w-4 text-slate-400\" />\n                <span>{data.settings.contactEmail}</span>\n              </a>\n              <span className=\"hidden sm:inline text-slate-200\">|</span>\n              <a href={`tel:${data.settings.contactPhone}`} className=\"hover:text-sky-500 flex items-center space-x-1\">\n                <Phone className=\"h-4 w-4 text-slate-400\" />\n                <span>{data.settings.contactPhone}</span>\n              </a>\n            </div>\n          </div>\n\n          <div className=\"flex flex-col sm:flex-row items-center justify-between text-2xs text-slate-400 font-medium\">\n            <p>\n              \302\251 {new Date().getFullYear()} {lang === \"ru\" ? \"\320\223\320\273\320\260\320\262\320\275\320\276\320\265 \320\236\320\261\321\200\320\260\320\267\320\276\320\262\320\260\321\202\320\265\320\273\321\214\320\275\320\276\320\265 \320\241\320\276\320\261\321\213\321\202\320\270\320\265 \320\223\320\276\320\264\320\260.\" : \"The Main Educational Event of the Year.\"} All Rights Reserved.\n            </p>\n            <p className=\"mt-2 sm:mt-0 font-mono\">\n              Designed with Light/Airy Minimalism \342\200\242 Powered by Technopark Hub\n            </p>\n          </div>\n\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
    }
