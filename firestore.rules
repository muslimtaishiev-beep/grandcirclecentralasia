rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is an admin by email
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "admin@mainedu.kz" || 
        request.auth.token.email == "muslim.taishiev@gmail.com"
      );
    }

    match /users/{userId} {
      // User can read/write their own document. Admin can do everything.
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /decisions/{decisionId} {
      // Anyone can read decisions (used during Signup to see pre-set decision)
      allow read: if true;
      // Only admins can write decisions
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      // Settings are read-only for public, write for admin
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
